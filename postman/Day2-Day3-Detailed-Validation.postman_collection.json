                                                                   "pm.test(\u0027200\u0027,()=\u003epm.response.to.have.status(200));",
                                                                   "const list=pm.response.json(); const sid=pm.environment.get(\u0027subscriptionId\u0027); const row=list.find(x=\u003ex.id===sid); pm.expect(row,\u0027subscription exists\u0027).to.exist;",
                                                                   "pm.expect(row.amount).to.be.a(\u0027number\u0027);",
                                                                   "pm.expect(row.originalAmount).to.eql(undefined);",
                                                                   "pm.expect(row.actualAmount).to.eql(undefined);"
                                                               ]

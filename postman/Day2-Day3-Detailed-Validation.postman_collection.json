    "item":  [
                 {
                     "name":  "1) Login",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\"email\":\"{{email}}\",\"password\":\"{{password}}\",\"clientId\":\"{{clientId}}\"}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/sso/generate-token",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "sso",
                                                              "generate-token"
                                                          ]
                                             }
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027200\u0027,()=\u003epm.response.to.have.status(200));",
                                                                   "const j=pm.response.json(); pm.expect(j.accessToken).to.be.a(\u0027string\u0027).and.not.empty; pm.environment.set(\u0027token\u0027,j.accessToken);"
                                                               ]
                                                  }
                                   }
                               ]
                 },

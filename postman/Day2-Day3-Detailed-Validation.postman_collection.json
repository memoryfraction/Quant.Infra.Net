                                                              "payment",
                                                              "status",
                                                              "{{orderId}}"
                                                          ]
                                             }
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027200\u0027,()=\u003epm.response.to.have.status(200));",
                                                                   "const j=pm.response.json(); pm.expect(j.paid).to.eql(true); pm.expect(j.subscriptionId).to.be.a(\u0027string\u0027).and.not.empty; pm.environment.set(\u0027subscriptionId\u0027,j.subscriptionId);"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "7) My subscriptions (activeOnly)",
                     "request":  {

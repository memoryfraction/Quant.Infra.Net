    {
      "name": "12) Status - Failed Should Be Cancelled + Failed Tx",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/payment/status/{{orderIdFailed}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "payment", "status", "{{orderIdFailed}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const obj = pm.response.json();",
              "pm.test('Order cancelled + failed transaction', function () {",
              "  pm.expect(obj.orderStatus).to.eql(2);",
              "  pm.expect(obj.paid).to.eql(false);",
              "  pm.expect(obj.transactionStatus).to.eql(2);",
              "});"
            ]

@page
@model DashboardModel
@{
    ViewData["Title"] = "Schwab Trading Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: Segoe UI, Arial, sans-serif; background: #f5f7fb; color: #182033; }
        .shell { max-width: 1360px; margin: 0 auto; padding: 28px 20px 48px; }
        .header { background: linear-gradient(135deg, #6275ee, #7548a8); color: #fff; padding: 22px 28px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 8px 24px rgba(31,35,67,.16); }
        .header h1 { margin: 0; font-size: 24px; font-weight: 700; }
        .logout-btn, .btn { border: 0; border-radius: 6px; padding: 10px 18px; font-weight: 700; cursor: pointer; }
        .logout-btn { color: #fff; background: rgba(255,255,255,.16); border: 2px solid rgba(255,255,255,.8); }
        .btn { color: #fff; background: linear-gradient(135deg, #6275ee, #7548a8); }
        .notice { margin: 22px 0; padding: 14px 18px; border-left: 4px solid #f5b400; background: #fff2c8; border-radius: 6px; }
        .error { margin: 22px 0; padding: 14px 18px; border-left: 4px solid #e13d3d; background: #ffe7e7; border-radius: 6px; }
        .tabs { display: flex; gap: 18px; border-bottom: 2px solid #d9deea; margin: 26px 0 28px; }
        .tab { background: none; border: 0; border-bottom: 3px solid transparent; padding: 14px 4px; color: #5c657a; font-size: 16px; font-weight: 700; cursor: pointer; }
        .tab.active { color: #6275ee; border-bottom-color: #6275ee; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; margin-bottom: 26px; }
        .stat { background: linear-gradient(135deg, #6275ee, #7548a8); color: #fff; padding: 24px; border-radius: 8px; box-shadow: 0 8px 20px rgba(98,117,238,.25); }
        .stat .label { font-size: 13px; opacity: .9; margin-bottom: 10px; }
        .stat .value { font-size: 30px; font-weight: 800; }
        .card { background: #fff; border: 1px solid #dfe4ef; border-radius: 8px; box-shadow: 0 3px 12px rgba(26,36,68,.08); padding: 24px; margin-bottom: 20px; }
        .card h2 { margin: 0 0 18px; font-size: 20px; }
        .table-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 12px; border-bottom: 1px solid #edf0f6; white-space: nowrap; }
        th { color: #526078; background: #f7f9fc; font-weight: 800; }
        .positive { color: #148b45; font-weight: 700; }
        .negative { color: #c92f2f; font-weight: 700; }
        .empty { text-align: center; color: #8a94a8; padding: 34px; }
        .search { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 18px; }
        .search input { min-width: 260px; padding: 11px 13px; border: 2px solid #dfe4ef; border-radius: 6px; font-size: 14px; }
    </style>
</head>
<body>
<div class="shell">
    <div class="header">
        <h1>Schwab Trading Dashboard</h1>
        <form method="post" asp-page-handler="Logout"><button type="submit" class="logout-btn">Logout</button></form>
    </div>

    @if (Model.IsDemo)
    {
        <div class="notice"><strong>Demo mode.</strong> The values shown here are simulated.</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="error"><strong>Error:</strong> @Model.ErrorMessage</div>
    }

    <div class="tabs">
        <button class="tab @(Model.ActiveTab == "account" ? "active" : "")" type="button" onclick="showTab(event, 'account')">Account</button>
        <button class="tab @(Model.ActiveTab == "positions" ? "active" : "")" type="button" onclick="showTab(event, 'positions')">Positions</button>
        <button class="tab @(Model.ActiveTab == "quotes" ? "active" : "")" type="button" onclick="showTab(event, 'quotes')">Quotes</button>
        <button class="tab @(Model.ActiveTab == "options" ? "active" : "")" type="button" onclick="showTab(event, 'options')">Options</button>
        <button class="tab @(Model.ActiveTab == "orders" ? "active" : "")" type="button" onclick="showTab(event, 'orders')">Orders</button>
    </div>

    <section id="account" class="tab-content @(Model.ActiveTab == "account" ? "active" : "")">
        @if (Model.Account != null)
        {
            <div class="stats">
                <div class="stat"><div class="label">Total Equity</div><div class="value">$@Model.Account.TotalEquity.ToString("N2")</div></div>
                <div class="stat"><div class="label">Cash Balance</div><div class="value">$@Model.Account.CashBalance.ToString("N2")</div></div>
                <div class="stat"><div class="label">Market Value</div><div class="value">$@Model.Account.MarketValue.ToString("N2")</div></div>
                <div class="stat"><div class="label">Buying Power</div><div class="value">$@Model.Account.BuyingPower.ToString("N2")</div></div>
            </div>
            <div class="card">
                <h2>Account Details</h2>
                <table>
                    <tr><th>Account Number</th><td>@Model.Account.AccountNumber</td></tr>
                    <tr><th>Account Type</th><td>@Model.Account.AccountType</td></tr>
                    <tr><th>Unrealized P/L</th><td class="@(Model.Account.UnrealizedPnL >= 0 ? "positive" : "negative")">$@Model.Account.UnrealizedPnL.ToString("N2")</td></tr>
                    <tr><th>Realized P/L</th><td class="@(Model.Account.RealizedPnL >= 0 ? "positive" : "negative")">$@Model.Account.RealizedPnL.ToString("N2")</td></tr>
                </table>
            </div>
        }
        else
        {
            <div class="card empty">Account data is unavailable.</div>
        }
    </section>

    <section id="positions" class="tab-content @(Model.ActiveTab == "positions" ? "active" : "")">
        <div class="card">
            <h2>Positions</h2>
            @if (Model.Positions != null && Model.Positions.Count > 0)
            {
                <div class="table-wrap"><table><thead><tr><th>Symbol</th><th>Quantity</th><th>Cost Price</th><th>Asset Type</th><th>Unrealized P/L</th></tr></thead><tbody>
                @foreach (var pos in Model.Positions)
                {
                    <tr><td><strong>@pos.Symbol</strong></td><td>@pos.Quantity</td><td>$@pos.CostPrice.ToString("N2")</td><td>@pos.AssetType</td><td class="@(pos.UnrealizedProfitLoss >= 0 ? "positive" : "negative")">@(pos.UnrealizedProfitLoss.HasValue ? $"${pos.UnrealizedProfitLoss.Value:N2}" : "-")</td></tr>
                }
                </tbody></table></div>
            }
            else { <div class="empty">No positions found.</div> }
        </div>
    </section>

    <section id="quotes" class="tab-content @(Model.ActiveTab == "quotes" ? "active" : "")">
        <div class="card">
            <h2>Real-Time Quote</h2>
            <form class="search" method="post" asp-page-handler="GetQuote"><input name="symbol" placeholder="Symbol, e.g. AAPL" required /><button class="btn" type="submit">Get Quote</button></form>
            @if (Model.Quote != null)
            {
                <table>
                    <tr><th>Symbol</th><td>@Model.Quote.Symbol</td></tr>
                    <tr><th>Last</th><td>$@Model.Quote.LastPrice.ToString("N2")</td></tr>
                    <tr><th>Change</th><td class="@(Model.Quote.Change >= 0 ? "positive" : "negative")">@Model.Quote.Change.ToString("+0.00;-0.00") (@Model.Quote.ChangePercent.ToString("+0.00;-0.00")%)</td></tr>
                    <tr><th>Bid / Ask</th><td>$@Model.Quote.BidPrice.ToString("N2") / $@Model.Quote.AskPrice.ToString("N2")</td></tr>
                    <tr><th>High / Low</th><td>$@Model.Quote.High.ToString("N2") / $@Model.Quote.Low.ToString("N2")</td></tr>
                    <tr><th>Volume</th><td>@Model.Quote.Volume.ToString("N0")</td></tr>
                </table>
            }
        </div>
    </section>

    <section id="options" class="tab-content @(Model.ActiveTab == "options" ? "active" : "")">
        <div class="card">
            <h2>Option Chain</h2>
            <form class="search" method="post" asp-page-handler="GetOptionChain"><input name="symbol" placeholder="Underlying, e.g. AAPL" required /><button class="btn" type="submit">Get Chain</button></form>
            @if (Model.OptionChain != null)
            {
                <h3>@Model.OptionChain.Symbol - Underlying $@Model.OptionChain.UnderlyingPrice.ToString("N2")</h3>
                <h3>Calls</h3>
                <div class="table-wrap"><table><thead><tr><th>Expiration</th><th>Strike</th><th>Bid / Ask</th><th>Last</th><th>Volume</th><th>Open Interest</th><th>Delta</th><th>IV</th></tr></thead><tbody>
                @foreach (var call in Model.OptionChain.CallOptions.Take(20))
                {
                    <tr><td>@call.ExpirationDate</td><td>$@call.Strike.ToString("N2")</td><td>$@call.Bid.ToString("N2") / $@call.Ask.ToString("N2")</td><td>$@call.Last.ToString("N2")</td><td>@call.Volume.ToString("N0")</td><td>@call.OpenInterest.ToString("N0")</td><td>@call.Delta.ToString("N4")</td><td>@call.ImpliedVolatility.ToString("P2")</td></tr>
                }
                </tbody></table></div>
                <h3>Puts</h3>
                <div class="table-wrap"><table><thead><tr><th>Expiration</th><th>Strike</th><th>Bid / Ask</th><th>Last</th><th>Volume</th><th>Open Interest</th><th>Delta</th><th>IV</th></tr></thead><tbody>
                @foreach (var put in Model.OptionChain.PutOptions.Take(20))
                {
                    <tr><td>@put.ExpirationDate</td><td>$@put.Strike.ToString("N2")</td><td>$@put.Bid.ToString("N2") / $@put.Ask.ToString("N2")</td><td>$@put.Last.ToString("N2")</td><td>@put.Volume.ToString("N0")</td><td>@put.OpenInterest.ToString("N0")</td><td>@put.Delta.ToString("N4")</td><td>@put.ImpliedVolatility.ToString("P2")</td></tr>
                }
                </tbody></table></div>
            }
        </div>
    </section>

    <section id="orders" class="tab-content @(Model.ActiveTab == "orders" ? "active" : "")">
        <div class="card">
            <h2>Order History</h2>
            @if (Model.Orders != null && Model.Orders.Count > 0)
            {
                <div class="table-wrap"><table><thead><tr><th>Order ID</th><th>Symbol</th><th>Side</th><th>Type</th><th>Status</th><th>Qty</th><th>Filled</th><th>Limit</th><th>Avg Fill</th><th>Created</th></tr></thead><tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr><td>@order.OrderId</td><td><strong>@order.Symbol</strong></td><td>@order.Side</td><td>@order.OrderType</td><td>@order.Status</td><td>@order.Quantity</td><td>@order.FilledQuantity</td><td>@(order.LimitPrice.HasValue ? $"${order.LimitPrice.Value:N2}" : "-")</td><td>@(order.AverageFilledPrice.HasValue ? $"${order.AverageFilledPrice.Value:N2}" : "-")</td><td>@order.CreatedAt</td></tr>
                }
                </tbody></table></div>
            }
            else { <div class="empty">No orders found in the last 60 days.</div> }
        </div>
    </section>
</div>
<script>
function showTab(evt, name) {
    document.querySelectorAll('.tab-content').forEach(x => x.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    document.getElementById(name).classList.add('active');
    evt.currentTarget.classList.add('active');
}
</script>
</body>
</html>

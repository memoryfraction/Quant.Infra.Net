@page
@model IndexModel
@{
    ViewData["Title"] = "Schwab Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg,#667eea 0%,#764ba2 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            padding: 20px;
        }
        .card {
            background: white; border-radius: 12px;
            padding: 40px; width: 100%; max-width: 500px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .logo { text-align:center; margin-bottom:28px; }
        .logo h1 { font-size:22px; color:#333; }
        .logo p  { font-size:13px; color:#888; margin-top:4px; }

        .step {
            display: flex; align-items: flex-start; gap: 14px;
            margin-bottom: 20px;
        }
        .step-num {
            background: #667eea; color: white;
            border-radius: 50%; width: 28px; height: 28px;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 700; flex-shrink: 0; margin-top: 2px;
        }
        .step-body { flex: 1; }
        .step-body label { display:block; font-size:13px; font-weight:600; color:#444; margin-bottom:6px; }
        .step-body p { font-size:12px; color:#888; margin-bottom:8px; line-height:1.6; }

        input[type=text], input[type=password] {
            width:100%; padding:10px 12px;
            border:2px solid #e0e0e0; border-radius:7px;
            font-size:14px; transition:border-color .2s; margin-bottom:8px;
        }
        input:focus { outline:none; border-color:#667eea; }

        .btn {
            width:100%; padding:12px; border:none; border-radius:7px;
            font-size:15px; font-weight:700; cursor:pointer; transition:opacity .2s;
        }
        .btn-schwab { background:linear-gradient(135deg,#11998e,#38ef7d); color:white; }
        .btn-login  { background:linear-gradient(135deg,#667eea,#764ba2); color:white; }
        .btn:hover  { opacity:.88; }

        .divider { border:none; border-top:2px dashed #eee; margin:20px 0; }

        .code-hint {
            background:#fffbea; border:1px solid #ffe082; border-radius:7px;
            padding:12px 14px; font-size:12px; color:#795548; margin-bottom:8px;
            line-height:1.7;
        }
        .code-hint code { background:#fff3cd; padding:2px 6px; border-radius:3px; font-size:11px; }

        .error-box {
            background:#fff0f0; border-left:4px solid #e53935;
            border-radius:5px; padding:10px 14px; margin-bottom:16px;
            font-size:13px; color:#c62828;
        }
    </style>
</head>
<body>
<div class="card">
    <div class="logo">
        <h1>Charles Schwab</h1>
        <p>Quant Trading</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-box">⚠️ @Model.ErrorMessage</div>
    }

    <form method="post" asp-page-handler="StartAuth">
        <!-- Step 1: Credentials -->
        <div class="step">
            <div class="step-num">1</div>
            <div class="step-body">
                <label>Enter credentials</label>
                <input type="text"     name="appKey"        id="appKey"        placeholder="Client ID (App Key)" autocomplete="off" />
                <input type="password" name="appSecret"     id="appSecret"     placeholder="Client Secret" />
                <input type="text"     name="accountNumber" id="accountNumber" placeholder="Schwab account number" />
            </div>
        </div>

        <!-- Step 2: Open Schwab -->
        <div class="step">
            <div class="step-num">2</div>
            <div class="step-body">
                <label>Authorize with Schwab</label>
                <p>Click the button below, sign in to Schwab, and approve access. The browser will return here automatically.</p>
                <button type="submit" class="btn btn-schwab">Open Schwab Authorization</button>
            </div>
        </div>
    </form>

    <hr class="divider" />

    <!-- Demo mode shortcut -->
    <form method="post" asp-page-handler="Demo">
        <button type="submit" style="width:100%;padding:11px;border:2px dashed #bbb;border-radius:7px;
            background:#fafafa;color:#888;font-size:13px;cursor:pointer;margin-bottom:4px;">
            Demo mode (simulated data, no real account required)
        </button>
    </form>

    <div class="code-hint">
        Open this page from <code>https://127.0.0.1/</code>. After Schwab authorization, the app exchanges the authorization code for a token automatically.
    </div>
</div>

<script>
    // Keep this exactly the same as the Callback URL configured in the Schwab Developer Portal.
    const REDIRECT = "https://127.0.0.1";

    // Restore from sessionStorage on page load
    window.onload = () => {
        if (location.hostname === 'localhost') {
            location.href = 'https://127.0.0.1/';
            return;
        }

        const k = sessionStorage.getItem('appKey');
        const s = sessionStorage.getItem('appSecret');
        const a = sessionStorage.getItem('accountNumber');
        if (k) document.getElementById('appKey').value = k;
        if (s) document.getElementById('appSecret').value = s;
        if (a) document.getElementById('accountNumber').value = a;
    };

    document.querySelector('form[method="post"]').addEventListener('submit', () => {
        sessionStorage.setItem('appKey', document.getElementById('appKey').value);
        sessionStorage.setItem('appSecret', document.getElementById('appSecret').value);
        sessionStorage.setItem('accountNumber', document.getElementById('accountNumber').value);
    });
</script>
</body>
</html>

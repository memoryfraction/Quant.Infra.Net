@page "/oauth/callback"
@model OAuthCallbackModel
@{
    ViewData["Title"] = "授权中...";
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg,#667eea 0%,#764ba2 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
        }
        .card {
            background: white; border-radius: 12px;
            padding: 48px 40px; width: 460px; text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .icon { font-size: 64px; margin-bottom: 20px; }
        h2 { color: #333; margin-bottom: 12px; }
        p  { color: #666; line-height: 1.7; }
        .spinner {
            width: 40px; height: 40px;
            border: 4px solid #e0e0e0;
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 20px auto;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .error { color: #c62828; background: #fff0f0; padding: 14px; border-radius: 7px; margin-top: 16px; }
        .btn {
            display: inline-block; margin-top: 20px;
            padding: 12px 28px; background: linear-gradient(135deg,#667eea,#764ba2);
            color: white; border-radius: 7px; text-decoration: none; font-weight: 700;
        }
    </style>
</head>
<body>
<div class="card">
    @if (Model.Success)
    {
        <div class="icon">✅</div>
        <h2>授权成功！</h2>
        <p>正在跳转到仪表板...</p>
        <div class="spinner"></div>
        <script>setTimeout(() => window.location.href = '/Dashboard', 1500);</script>
    }
    else if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="icon">❌</div>
        <h2>授权失败</h2>
        <div class="error">@Model.ErrorMessage</div>
        <a href="/" class="btn">返回登录</a>
    }
    else
    {
        <div class="icon">🔄</div>
        <h2>正在处理授权...</h2>
        <div class="spinner"></div>
    }
</div>
</body>
</html>

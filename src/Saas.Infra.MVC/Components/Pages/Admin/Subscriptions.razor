@page "/admin/subscriptions"
@layout MainLayout
@attribute [Authorize(Roles = global::Saas.Infra.Core.RoleCodes.AdminOrSuperAdmin)]
@inject NavigationManager Nav
@using Microsoft.EntityFrameworkCore
@using Serilog

<PageTitle>Admin Subscriptions - Saas.Infra</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><i class="bi bi-list-check"></i> Subscription Management</h1>
        <a class="btn btn-outline-secondary" href="/admin">
            <i class="bi bi-arrow-left"></i> Back to Admin
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form class="row g-2" @onsubmit="OnFilterSubmitted">
                <div class="col-md-6">
                    <input type="text" class="form-control" placeholder="Search by user/email/product..." @bind="_filterKeyword" />
                </div>
                <div class="col-md-3">
                    <select class="form-select" @bind="_filterStatus">
                        <option value="">All Status</option>
                        <option value="0">Pending</option>
                        <option value="1">Active</option>
                        <option value="2">Cancelled</option>
                        <option value="3">Expired</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input id="includeDeleted" class="form-check-input" type="checkbox" @bind="_includeDeleted" />
                        <label class="form-check-label" for="includeDeleted">Show Deleted</label>
                    </div>
                </div>
                <div class="col-md-1 d-grid">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i> Filter</button>
                </div>
            </form>
        </div>
    </div>

    @if (_model.Items != null && _model.Items.Count > 0)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="text-muted">Selected: @_selectedSubscriptionIds.Count</div>
                <div class="btn-group btn-group-sm flex-wrap">
                    <button type="button" class="btn btn-outline-warning" @onclick="BulkCancelAsync">Bulk Cancel</button>
                    <button type="button" class="btn btn-outline-danger" @onclick="BulkDeleteAsync">Bulk Delete</button>
                    <button type="button" class="btn btn-outline-success" @onclick="BulkRestoreAsync">Bulk Restore</button>
                    <button type="button" class="btn btn-outline-primary" @onclick="BulkReopenAsync">Bulk Reopen</button>
                </div>
            </div>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (_isLoading)
            {
                <div class="p-4 text-center text-muted">Loading subscriptions...</div>
            }
            else if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="p-4 text-center text-danger">@_errorMessage</div>
            }
            else if (_model.Items != null && _model.Items.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    <input type="checkbox" class="form-check-input" checked="@AllVisibleSelected" @onchange="ToggleSelectAll" />
                                </th>
                                <th>User</th>
                                <th>Product</th>
                                <th>Plan</th>
                                <th>Status</th>
                                <th>Auto Renew</th>
                                <th>Created</th>
                                <th>ID</th>
                                 <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in _model.Items)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input" checked="@_selectedSubscriptionIds.Contains(item.Id)" @onchange="args => ToggleSelection(item.Id, args)" />
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.UserName</div>
                                    <small class="text-muted">@item.UserEmail</small>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.ProductName</div>
                                    <small class="text-muted">@item.ProductCode</small>
                                </td>
                                <td>@item.PriceName</td>
                                <td><span class="badge @(item.IsDeleted ? "bg-danger" : GetStatusBadge(item.Status))">@(item.IsDeleted ? "Deleted" : GetStatusText(item.Status))</span></td>
                                <td>@(item.AutoRenew ? "Yes" : "No")</td>
                                <td>@item.CreatedTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><code>@item.Id.ToString()[..8]</code></td>
                                 <td class="text-end">
                                     <div class="btn-group btn-group-sm">
                                         <button type="button" class="btn btn-outline-secondary" @onclick="() => ViewDetails(item.Id)">Details</button>
                                          @if (item.IsDeleted)
                                          {
                                              <button type="button" class="btn btn-outline-success" @onclick="() => RestoreSubscriptionAsync(item.Id)">Restore</button>
                                          }
                                          else
                                          {
                                              <button type="button" class="btn btn-outline-primary" @onclick="() => ToggleAutoRenewAsync(item.Id)">Auto Renew</button>
                                              @if (item.Status != 1)
                                              {
                                                  <button type="button" class="btn btn-outline-success" @onclick="() => ReopenSubscriptionAsync(item.Id)">Reopen</button>
                                              }
                                              <button type="button" class="btn btn-outline-warning" @onclick="() => CancelSubscriptionAsync(item.Id)">Cancel</button>
                                              <button type="button" class="btn btn-outline-danger" @onclick="() => DeleteSubscriptionAsync(item.Id)">Delete</button>
                                          }
                                     </div>
                                 </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted">No subscriptions found.</div>
            }
        </div>
    </div>
</div>

@code {
    private readonly AdminSubscriptionsPageViewModel _model = new();
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _filterKeyword;
    private string? _filterStatus;
    private bool _includeDeleted;
    private readonly HashSet<Guid> _selectedSubscriptionIds = new();

    [Inject]
    private ApplicationDbContext DbContext { get; set; } = default!;

    /// <summary>
    /// Loads initial subscriptions list.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptionsAsync().ConfigureAwait(false);
    }

    /// <summary>
    /// Handles filter form submission.
    /// </summary>
    private async Task OnFilterSubmitted()
    {
        if (!string.IsNullOrWhiteSpace(_filterKeyword) && _filterKeyword.Length > 200)
        {
            _errorMessage = "Keyword length cannot exceed 200 characters.";
            return;
        }

        short? parsedStatus = null;
        if (!string.IsNullOrWhiteSpace(_filterStatus) && short.TryParse(_filterStatus, out var statusValue))
        {
            parsedStatus = statusValue;
        }

        _model.Keyword = string.IsNullOrWhiteSpace(_filterKeyword) ? null : _filterKeyword.Trim();
        _model.Status = parsedStatus;
        _model.IncludeDeleted = _includeDeleted;

        await LoadSubscriptionsAsync().ConfigureAwait(false);
    }

    /// <summary>
    /// Loads subscriptions from the database according to the current filter.
    /// </summary>
    private async Task LoadSubscriptionsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var query = DbContext.Subscriptions
                .AsNoTracking()
                .Include(s => s.User)
                .Include(s => s.Product)
                .Include(s => s.Price)
                .AsQueryable();

            if (!_model.IncludeDeleted)
            {
                query = query.Where(s => !s.IsDeleted);
            }

            if (_model.Status.HasValue)
            {
                query = query.Where(s => s.Status == _model.Status.Value);
            }

            if (!string.IsNullOrWhiteSpace(_model.Keyword))
            {
                var normalized = _model.Keyword.Trim().ToLowerInvariant();
                query = query.Where(s =>
                    (s.User != null && ((s.User.UserName != null && s.User.UserName.ToLower().Contains(normalized)) ||
                                        (s.User.Email != null && s.User.Email.ToLower().Contains(normalized)))) ||
                    (s.Product != null && ((s.Product.Code != null && s.Product.Code.ToLower().Contains(normalized)) ||
                                           (s.Product.Name != null && s.Product.Name.ToLower().Contains(normalized)))) ||
                    (s.Price != null && s.Price.Name != null && s.Price.Name.ToLower().Contains(normalized)));
            }

            var items = await query
                .OrderByDescending(s => s.CreatedTime)
                .Take(200)
                .Select(s => new AdminSubscriptionItemViewModel
                {
                    Id = s.Id,
                    UserName = s.User != null ? (s.User.UserName ?? string.Empty) : string.Empty,
                    UserEmail = s.User != null ? (s.User.Email ?? string.Empty) : string.Empty,
                    ProductCode = s.Product != null ? (s.Product.Code ?? string.Empty) : string.Empty,
                    ProductName = s.Product != null ? (s.Product.Name ?? string.Empty) : string.Empty,
                    PriceName = s.Price != null ? (s.Price.Name ?? string.Empty) : string.Empty,
                    Status = s.Status,
                    AutoRenew = s.AutoRenew,
                    EndDate = s.EndDate,
                    IsDeleted = s.IsDeleted,
                    CreatedTime = s.CreatedTime
                })
                .ToListAsync()
                .ConfigureAwait(false);

            _model.Items = items;
            _selectedSubscriptionIds.IntersectWith(items.Select(item => item.Id));
            Log.Information("Admin subscriptions (Blazor) loaded {Count} rows", items.Count);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error loading admin subscriptions in Blazor component");
            _errorMessage = "An error occurred while loading subscriptions.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Gets display text for a subscription status.
    /// </summary>
    /// <param name="status">Status value.</param>
    /// <returns>Status text.</returns>
    private static string GetStatusText(short status) => status switch
    {
        0 => "Pending",
        1 => "Active",
        2 => "Cancelled",
        3 => "Expired",
        _ => "Unknown"
    };

    /// <summary>
    /// Gets CSS class for a subscription status badge.
    /// </summary>
    /// <param name="status">Status value.</param>
    /// <returns>CSS class string.</returns>
    private static string GetStatusBadge(short status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-success",
        2 => "bg-secondary",
        3 => "bg-dark",
        _ => "bg-light text-dark"
    };

    /// <summary>
    /// Navigates to the subscription details page.
    /// </summary>
    /// <param name="id">Subscription identifier.</param>
    private void ViewDetails(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        Nav.NavigateTo($"/subscriptions/{id}");
    }

    /// <summary>
    /// Cancels a subscription from the admin monitoring page.
    /// </summary>
    /// <param name="id">Subscription identifier.</param>
    private async Task CancelSubscriptionAsync(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        try
        {
            var subscription = await DbContext.Subscriptions.FirstOrDefaultAsync(s => s.Id == id && !s.IsDeleted).ConfigureAwait(false);
            if (subscription == null)
            {
                _errorMessage = "Subscription was not found.";
                return;
            }

            subscription.Status = 2;
            subscription.AutoRenew = false;
            await DbContext.SaveChangesAsync().ConfigureAwait(false);

            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error cancelling subscription {SubscriptionId} from admin page", id);
            _errorMessage = "An error occurred while cancelling the subscription.";
        }
    }

    /// <summary>
    /// Toggles auto-renew for a subscription from the admin monitoring page.
    /// </summary>
    /// <param name="id">Subscription identifier.</param>
    private async Task ToggleAutoRenewAsync(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        try
        {
            var subscription = await DbContext.Subscriptions.FirstOrDefaultAsync(s => s.Id == id && !s.IsDeleted).ConfigureAwait(false);
            if (subscription == null)
            {
                _errorMessage = "Subscription was not found.";
                return;
            }

            subscription.AutoRenew = !subscription.AutoRenew;
            await DbContext.SaveChangesAsync().ConfigureAwait(false);

            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error toggling auto renew for subscription {SubscriptionId} from admin page", id);
            _errorMessage = "An error occurred while updating auto renew.";
        }
    }

    /// <summary>
    /// Soft deletes a subscription from the admin monitoring page.
    /// </summary>
    /// <param name="id">Subscription identifier.</param>
    private async Task DeleteSubscriptionAsync(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        try
        {
            var subscription = await DbContext.Subscriptions.FirstOrDefaultAsync(s => s.Id == id && !s.IsDeleted).ConfigureAwait(false);
            if (subscription == null)
            {
                _errorMessage = "Subscription was not found.";
                return;
            }

            subscription.IsDeleted = true;
            subscription.AutoRenew = false;
            await DbContext.SaveChangesAsync().ConfigureAwait(false);

            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error deleting subscription {SubscriptionId} from admin page", id);
            _errorMessage = "An error occurred while deleting the subscription.";
        }
    }

    /// <summary>
    /// Restores a soft-deleted subscription from the admin monitoring page.
    /// </summary>
    /// <param name="id">Subscription identifier.</param>
    private async Task RestoreSubscriptionAsync(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        try
        {
            var subscription = await DbContext.Subscriptions.FirstOrDefaultAsync(s => s.Id == id).ConfigureAwait(false);
            if (subscription == null)
            {
                _errorMessage = "Subscription was not found.";
                return;
            }

            subscription.IsDeleted = false;
            await DbContext.SaveChangesAsync().ConfigureAwait(false);

            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error restoring subscription {SubscriptionId} from admin page", id);
            _errorMessage = "An error occurred while restoring the subscription.";
        }
    }

    /// <summary>
    /// Reopens a non-active subscription from the admin monitoring page.
    /// </summary>
    /// <param name="id">Subscription identifier.</param>
    private async Task ReopenSubscriptionAsync(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        try
        {
            var subscription = await DbContext.Subscriptions
                .Include(s => s.Price)
                .FirstOrDefaultAsync(s => s.Id == id && !s.IsDeleted)
                .ConfigureAwait(false);
            if (subscription == null)
            {
                _errorMessage = "Subscription was not found.";
                return;
            }

            subscription.Status = 1;
            subscription.AutoRenew = true;
            subscription.EndDate = CalculateRenewedEndDate(subscription.Price?.BillingPeriod, subscription.EndDate);
            await DbContext.SaveChangesAsync().ConfigureAwait(false);

            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error reopening subscription {SubscriptionId} from admin page", id);
            _errorMessage = "An error occurred while reopening the subscription.";
        }
    }

    /// <summary>
    /// Calculates the renewed end date for a reopened subscription.
    /// </summary>
    /// <param name="billingPeriod">Billing period.</param>
    /// <param name="currentEndDate">Current subscription end date.</param>
    /// <returns>Renewed end date.</returns>
    private static DateTimeOffset CalculateRenewedEndDate(string? billingPeriod, DateTimeOffset? currentEndDate)
    {
        var baseDate = currentEndDate.HasValue && currentEndDate.Value > DateTimeOffset.UtcNow
            ? currentEndDate.Value
            : DateTimeOffset.UtcNow;

        return billingPeriod?.ToLowerInvariant() switch
        {
            "week" => baseDate.AddDays(7),
            "year" => baseDate.AddYears(1),
            _ => baseDate.AddMonths(1)
        };
    }

    private bool AllVisibleSelected => _model.Items.Count > 0 && _model.Items.All(item => _selectedSubscriptionIds.Contains(item.Id));

    private void ToggleSelectAll(ChangeEventArgs args)
    {
        var isChecked = args?.Value is bool boolValue && boolValue;
        if (!isChecked)
        {
            _selectedSubscriptionIds.Clear();
            return;
        }

        foreach (var item in _model.Items)
        {
            _selectedSubscriptionIds.Add(item.Id);
        }
    }

    private void ToggleSelection(Guid id, ChangeEventArgs args)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        var isChecked = args?.Value is bool boolValue && boolValue;
        if (isChecked)
        {
            _selectedSubscriptionIds.Add(id);
            return;
        }

        _selectedSubscriptionIds.Remove(id);
    }

    private async Task BulkCancelAsync()
    {
        if (_selectedSubscriptionIds.Count == 0)
        {
            _errorMessage = "Select at least one subscription.";
            return;
        }

        try
        {
            var subscriptions = await DbContext.Subscriptions
                .Where(s => _selectedSubscriptionIds.Contains(s.Id) && !s.IsDeleted)
                .ToListAsync()
                .ConfigureAwait(false);

            foreach (var subscription in subscriptions)
            {
                subscription.Status = 2;
                subscription.AutoRenew = false;
            }

            await DbContext.SaveChangesAsync().ConfigureAwait(false);
            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error performing bulk cancel in admin subscriptions page");
            _errorMessage = "An error occurred while bulk cancelling subscriptions.";
        }
    }

    private async Task BulkDeleteAsync()
    {
        if (_selectedSubscriptionIds.Count == 0)
        {
            _errorMessage = "Select at least one subscription.";
            return;
        }

        try
        {
            var subscriptions = await DbContext.Subscriptions
                .Where(s => _selectedSubscriptionIds.Contains(s.Id) && !s.IsDeleted)
                .ToListAsync()
                .ConfigureAwait(false);

            foreach (var subscription in subscriptions)
            {
                subscription.IsDeleted = true;
                subscription.AutoRenew = false;
            }

            await DbContext.SaveChangesAsync().ConfigureAwait(false);
            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error performing bulk delete in admin subscriptions page");
            _errorMessage = "An error occurred while bulk deleting subscriptions.";
        }
    }

    private async Task BulkRestoreAsync()
    {
        if (_selectedSubscriptionIds.Count == 0)
        {
            _errorMessage = "Select at least one subscription.";
            return;
        }

        try
        {
            var subscriptions = await DbContext.Subscriptions
                .Where(s => _selectedSubscriptionIds.Contains(s.Id) && s.IsDeleted)
                .ToListAsync()
                .ConfigureAwait(false);

            foreach (var subscription in subscriptions)
            {
                subscription.IsDeleted = false;
            }

            await DbContext.SaveChangesAsync().ConfigureAwait(false);
            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error performing bulk restore in admin subscriptions page");
            _errorMessage = "An error occurred while bulk restoring subscriptions.";
        }
    }

    private async Task BulkReopenAsync()
    {
        if (_selectedSubscriptionIds.Count == 0)
        {
            _errorMessage = "Select at least one subscription.";
            return;
        }

        try
        {
            var subscriptions = await DbContext.Subscriptions
                .Include(s => s.Price)
                .Where(s => _selectedSubscriptionIds.Contains(s.Id) && !s.IsDeleted)
                .ToListAsync()
                .ConfigureAwait(false);

            foreach (var subscription in subscriptions)
            {
                subscription.Status = 1;
                subscription.AutoRenew = true;
                subscription.EndDate = CalculateRenewedEndDate(subscription.Price?.BillingPeriod, subscription.EndDate);
            }

            await DbContext.SaveChangesAsync().ConfigureAwait(false);
            await LoadSubscriptionsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "Error performing bulk reopen in admin subscriptions page");
            _errorMessage = "An error occurred while bulk reopening subscriptions.";
        }
    }
}

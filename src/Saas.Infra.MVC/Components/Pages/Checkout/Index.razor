@page "/checkout"
@layout MainLayout
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject BlazorTokenService TokenService

@using Microsoft.AspNetCore.Components
@using Saas.Infra.MVC.Models.Requests
@using Saas.Infra.MVC.Models.Responses

<PageTitle>Checkout - Saas.Infra</PageTitle>

@if (_isLoading)
{
    <div class="container py-5">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading checkout details...</p>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="container py-5">
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    </div>
}
else if (_price is null)
{
    <div class="container py-5">
        <div class="alert alert-warning" role="alert">Price information was not found.</div>
    </div>
}
else
{
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="mb-4">
                    <button type="button" class="btn btn-outline-secondary" @onclick="NavigateBackToProduct">
                        <i class="bi bi-arrow-left"></i> Back to Product
                    </button>
                </div>

                @if (Canceled)
                {
                    <div class="alert alert-warning" role="alert">
                        Payment was canceled. You can review the order and try again.
                    </div>
                }

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="bi bi-cart-check"></i> Order Summary
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <h5 class="mb-2">@(_price.ProductName ?? "Product")</h5>
                                <p class="text-muted mb-1">@_price.Name</p>
                                <small class="text-muted">Billing Period: @_price.BillingPeriod</small>
                            </div>
                            <div class="col-md-4 text-end">
                                <div class="display-6 fw-bold text-primary">
                                    @_price.Currency @((_price.Amount / 100.0m).ToString("F2"))
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header">
                        <h4 class="mb-0">
                            <i class="bi bi-credit-card"></i> Secure Payment
                        </h4>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-shield-check"></i>
                            <small>You will be redirected to Stripe's hosted payment page. No client-side payment JavaScript is required.</small>
                        </div>

                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg" type="button" disabled="@_isRedirecting" @onclick="StartHostedCheckoutAsync">
                                @if (_isRedirecting)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                    <span class="ms-2">Redirecting...</span>
                                }
                                else
                                {
                                    <span>Pay @_price.Currency @((_price.Amount / 100.0m).ToString("F2"))</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <small class="text-muted">
                        <i class="bi bi-lock-fill"></i> Secure payment powered by Stripe Checkout
                    </small>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .card-header.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 0.75rem 1.5rem;
    }

    .btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .btn-primary:disabled {
        opacity: 0.65;
    }
</style>

@code {
    /// <summary>
    /// 价格ID查询参数。
    /// Price ID query parameter.
    /// </summary>
    [SupplyParameterFromQuery]
    public Guid PriceId { get; set; }

    /// <summary>
    /// 取消支付查询参数。
    /// Payment canceled query parameter.
    /// </summary>
    [SupplyParameterFromQuery]
    public bool Canceled { get; set; }

    private PriceDto? _price;
    private bool _isLoading = true;
    private bool _isRedirecting;
    private string? _errorMessage;

    /// <summary>
    /// 加载结账所需的价格信息。
    /// Loads the price information required by checkout.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated || string.IsNullOrWhiteSpace(TokenService.AccessToken))
        {
            Nav.NavigateTo($"/account/login?returnUrl={Uri.EscapeDataString($"/checkout?priceId={PriceId}")}", forceLoad: true);
            return;
        }

        if (PriceId == Guid.Empty)
        {
            _errorMessage = "Invalid price identifier.";
            _isLoading = false;
            return;
        }

        await LoadPriceAsync().ConfigureAwait(false);
    }

    private async Task LoadPriceAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.GetAsync($"/api/prices/{PriceId}").ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo($"/account/login?returnUrl={Uri.EscapeDataString($"/checkout?priceId={PriceId}")}", forceLoad: true);
                    return;
                }

                _errorMessage = "Failed to load checkout information.";
                return;
            }

            _price = await response.Content.ReadFromJsonAsync<PriceDto>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (_price == null)
            {
                _errorMessage = "Price information was not found.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while loading checkout information: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task StartHostedCheckoutAsync()
    {
        if (_price == null)
        {
            _errorMessage = "Price information was not found.";
            return;
        }

        _isRedirecting = true;
        _errorMessage = null;

        try
        {
            var origin = new Uri(Nav.BaseUri);
            var successUrl = $"{origin.Scheme}://{origin.Authority}/checkout/success?session_id={{CHECKOUT_SESSION_ID}}&priceId={PriceId}";
            var cancelUrl = $"{origin.Scheme}://{origin.Authority}/checkout?priceId={PriceId}&canceled=true";

            var request = new CreateCheckoutSessionRequest
            {
                PriceId = PriceId,
                Gateway = "Stripe",
                SuccessUrl = successUrl,
                CancelUrl = cancelUrl
            };

            var client = CreateAuthorizedClient();
            var response = await client.PostAsJsonAsync("/api/payment/checkout-session", request).ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to start checkout.";
                return;
            }

            var session = await response.Content.ReadFromJsonAsync<CheckoutSessionDto>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (session == null || string.IsNullOrWhiteSpace(session.Url))
            {
                _errorMessage = "The hosted checkout URL was not returned.";
                return;
            }

            Nav.NavigateTo(session.Url, forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while starting checkout: {ex.Message}";
        }
        finally
        {
            _isRedirecting = false;
        }
    }

    private void NavigateBackToProduct()
    {
        if (_price == null || _price.ProductId == Guid.Empty)
        {
            Nav.NavigateTo("/products");
            return;
        }

        Nav.NavigateTo($"/products/{_price.ProductId}");
    }

    private HttpClient CreateAuthorizedClient()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? Nav.BaseUri.TrimEnd('/');
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(apiBaseUrl);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenService.AccessToken);

        return client;
    }
}

@page "/dashboard"
@layout MainLayout
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject Saas.Infra.MVC.Services.Product.IProductConfigService ProductConfigService
@inject Saas.Infra.MVC.Services.Blazor.BlazorTokenService TokenService

@using Saas.Infra.MVC.Models
@using Saas.Infra.MVC.Controllers.Mvc

<PageTitle>User Dashboard - Saas.Infra</PageTitle>

@if (_isLoading)
{
    <div class="container py-5">
        <p>Loading dashboard...</p>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="container py-5">
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    </div>
}
else
{
    <div class="container">
        <div class="welcome-section">
            <h1>User Dashboard - <span>@_model.Username</span></h1>
            <p>You are successfully logged in to Saas.Infra</p>
        </div>

        @if (_model.Products != null && _model.Products.Any())
        {
            <div class="product-container card" style="margin-bottom:20px; padding:20px;">
                <h2 style="margin-bottom:12px;">Available Products</h2>
                <div class="row">
                    @foreach (var product in _model.Products)
                    {
                        <div class="col-md-4" style="margin-bottom:12px;">
                            <div class="card h-100" style="padding:12px;">
                                <div style="padding-top:8px;">
                                    <h5>@product.Name</h5>
                                    @if (!string.IsNullOrEmpty(product.Description))
                                    {
                                        <p style="color:#666; font-size:14px;">@product.Description</p>
                                    }
                                    <a class="btn btn-primary" href="#">View Details</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="dashboard-grid">
            <div class="card">
                <div class="card-header">
                    <div class="card-icon">📊</div>
                    <div class="card-title">Account Status</div>
                </div>
                <div class="card-content">
                    Your account is active and in good standing.
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon">🔒</div>
                    <div class="card-title">Security</div>
                </div>
                <div class="card-content">
                    Your account is protected with JWT authentication.
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon">⚙️</div>
                    <div class="card-title">Settings</div>
                </div>
                <div class="card-content">
                    Customize your account preferences and settings.
                </div>
            </div>
        </div>

        <div class="profile-section">
            <h2>Account Information</h2>
            <div class="profile-item">
                <span class="profile-label">Username</span>
                <span class="profile-value">@_model.Username</span>
            </div>
            <div class="profile-item">
                <span class="profile-label">User ID</span>
                <span class="profile-value">@(_model.Id == Guid.Empty ? "N/A" : _model.Id.ToString())</span>
            </div>
            <div class="profile-item">
                <span class="profile-label">Account Created</span>
                <span class="profile-value">@(_model.CreatedAt == default ? "N/A" : _model.CreatedAtFormatted)</span>
            </div>
            <div class="profile-item">
                <span class="profile-label">Account Status</span>
                <span class="profile-value">@_model.AccountStatus</span>
            </div>
        </div>
    </div>
}

<style>
    .welcome-section {
        background: white;
        border-radius: 10px;
        padding: 30px;
        margin-bottom: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .welcome-section h1 {
        font-size: 28px;
        margin-bottom: 10px;
        color: #333;
    }

    .welcome-section p {
        color: #666;
        font-size: 14px;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .card {
        background: white;
        border-radius: 10px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    .card-header {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

    .card-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-right: 12px;
    }

    .card-title {
        font-size: 16px;
        font-weight: 600;
        color: #333;
    }

    .card-content {
        color: #666;
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 15px;
    }

    .profile-section {
        background: white;
        border-radius: 10px;
        padding: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .profile-section h2 {
        font-size: 20px;
        margin-bottom: 20px;
        color: #333;
    }

    .profile-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .profile-item:last-child {
        border-bottom: none;
    }

    .profile-label {
        color: #666;
        font-size: 14px;
    }

    .profile-value {
        color: #333;
        font-weight: 600;
        font-size: 14px;
    }
</style>

@code {
    private readonly DashboardViewModel _model = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    /// <summary>
    /// Loads the dashboard data for the current user.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated || string.IsNullOrWhiteSpace(TokenService.AccessToken))
        {
            Nav.NavigateTo("/account/login?returnUrl=/dashboard", forceLoad: true);
            return;
        }

        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? Nav.BaseUri.TrimEnd('/');
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri(apiBaseUrl);
            client.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenService.AccessToken);

            var response = await client.GetAsync("/api/users/me");
            if (!response.IsSuccessStatusCode)
            {
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo("/account/login?returnUrl=/dashboard", forceLoad: true);
                    return;
                }

                _errorMessage = "Failed to load account details.";
                return;
            }

            var userProfile = await response.Content.ReadFromJsonAsync<UserProfileViewModel>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            if (userProfile == null)
            {
                _errorMessage = "Failed to parse user profile.";
                return;
            }

            _model.Id = userProfile.Id;
            _model.Username = userProfile.Username;
            _model.Email = userProfile.Email;
            _model.CreatedAt = userProfile.CreatedAt;
            _model.AccountStatus = userProfile.Status == 1 ? "Active" : "Disabled";
            _model.AccessToken = TokenService.AccessToken;

            try
            {
                var products = await ProductConfigService.GetAvailableProductsAsync(userProfile.Username);
                if (products != null && products.Any())
                {
                    _model.Products = products.ToList();
                }
            }
            catch
            {
                _model.WarningMessage = "Failed to load available products.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while loading the dashboard: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}

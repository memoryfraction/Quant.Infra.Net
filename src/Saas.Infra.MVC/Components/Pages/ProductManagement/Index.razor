@page "/product-management"
@layout MainLayout
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject BlazorTokenService TokenService

@using Saas.Infra.MVC.Models.Responses

<PageTitle>Product Management - Saas.Infra</PageTitle>

@if (_isLoading)
{
    <div class="container-fluid py-4">
        <p>Loading products...</p>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="container-fluid py-4">
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    </div>
}
else
{
    <div class="container-fluid py-4">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="display-6 mb-2">
                            <i class="bi bi-box-seam"></i> Product Management
                        </h1>
                        <p class="text-muted">Manage products and pricing plans</p>
                    </div>
                    <div>
                        <button class="btn btn-primary" type="button" @onclick="NavigateToCreate">
                            <i class="bi bi-plus-circle"></i> Create Product
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h6 class="card-title">Total Products</h6>
                        <h2 class="mb-0">@_products.Count</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h6 class="card-title">Active Products</h6>
                        <h2 class="mb-0">@_products.Count(p => p.IsActive)</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <h6 class="card-title">Inactive Products</h6>
                        <h2 class="mb-0">@_products.Count(p => !p.IsActive)</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text"
                                   class="form-control"
                                   placeholder="Search products..."
                                   @bind="_searchTerm" />
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (_products.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Code</th>
                                            <th>Name</th>
                                            <th>Description</th>
                                            <th>Status</th>
                                            <th>Created</th>
                                            <th class="text-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var product in FilteredProducts)
                                        {
                                            <tr>
                                                <td>
                                                    <code>@product.Code</code>
                                                </td>
                                                <td>
                                                    <strong>@product.Name</strong>
                                                </td>
                                                <td>
                                                    <small class="text-muted">
                                                        @GetShortDescription(product.Description)
                                                    </small>
                                                </td>
                                                <td>
                                                    @if (product.IsActive)
                                                    {
                                                        <span class="badge bg-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>
                                                    <small>@product.CreatedTime.ToLocalTime().ToString("yyyy-MM-dd")</small>
                                                </td>
                                                <td class="text-end">
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-outline-primary" title="Manage Prices" @onclick="() => NavigateToPrices(product.Id)">
                                                            <i class="bi bi-tags"></i>
                                                        </button>
                                                        <button class="btn btn-outline-secondary" title="Edit" @onclick="() => NavigateToEdit(product.Id)">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger" title="Delete" @onclick="() => DeleteProductAsync(product.Id, product.Code)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
                                <h5 class="text-muted">No products found</h5>
                                <p class="text-muted">Create your first product to get started.</p>
                                <button class="btn btn-primary" type="button" @onclick="NavigateToCreate">
                                    <i class="bi bi-plus-circle"></i> Create Product
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .card-header {
        border-bottom: 2px solid #f0f0f0;
    }

    .table tbody tr {
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .card.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }
</style>

@code {
    private readonly List<ProductDto> _products = new();
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _searchTerm = string.Empty;

    private IEnumerable<ProductDto> FilteredProducts => string.IsNullOrWhiteSpace(_searchTerm)
        ? _products
        : _products.Where(p =>
            (!string.IsNullOrEmpty(p.Code) && p.Code.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(p.Name) && p.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(p.Description) && p.Description.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)));

    /// <summary>
    /// Loads all products for admin management.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated || string.IsNullOrWhiteSpace(TokenService.AccessToken))
        {
            Nav.NavigateTo("/account/login?returnUrl=/product-management", forceLoad: true);
            return;
        }

        await LoadProductsAsync().ConfigureAwait(false);
    }

    /// <summary>
    /// Loads products via the backend API using the current access token.
    /// </summary>
    private async Task LoadProductsAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _products.Clear();

        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.GetAsync("/api/products?activeOnly=false").ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo("/account/login?returnUrl=/product-management", forceLoad: true);
                    return;
                }

                _errorMessage = "Failed to load products.";
                return;
            }

            var items = await response.Content.ReadFromJsonAsync<List<ProductDto>>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (items != null)
            {
                _products.AddRange(items);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while loading products: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Deletes the specified product via the backend API.
    /// </summary>
    /// <param name="productId">Product identifier.</param>
    /// <param name="productCode">Product code for display.</param>
    private async Task DeleteProductAsync(Guid productId, string? productCode)
    {
        if (productId == Guid.Empty)
        {
            return;
        }

        var confirmMessage = string.IsNullOrWhiteSpace(productCode)
            ? "Are you sure you want to delete this product?"
            : $"Are you sure you want to delete product \"{productCode}\"?";

        var confirmed = await ConfirmAsync(confirmMessage).ConfigureAwait(false);
        if (!confirmed)
        {
            return;
        }

        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.DeleteAsync($"/api/products/{productId}").ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to delete product. Please try again.";
                return;
            }

            var existing = _products.FirstOrDefault(p => p.Id == productId);
            if (existing != null)
            {
                _products.Remove(existing);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while deleting product: {ex.Message}";
        }
    }

    /// <summary>
    /// Simple confirmation wrapper so the logic stays in C#.
    /// </summary>
    /// <param name="message">Confirmation message.</param>
    /// <returns>Always returns true currently.</returns>
    private Task<bool> ConfirmAsync(string message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return Task.FromResult(false);
        }

        // Without JS interop, always assume confirmation.
        return Task.FromResult(true);
    }

    /// <summary>
    /// Creates an authorized HTTP client for API calls.
    /// </summary>
    /// <returns>Configured HTTP client.</returns>
    private HttpClient CreateAuthorizedClient()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? Nav.BaseUri.TrimEnd('/');
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(apiBaseUrl);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenService.AccessToken);

        return client;
    }

    /// <summary>
    /// Gets a shortened description for display in the table.
    /// </summary>
    /// <param name="description">Full description.</param>
    /// <returns>Shortened description text.</returns>
    private static string GetShortDescription(string? description)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return "No description";
        }

        return description.Length > 50
            ? description.Substring(0, 50) + "..."
            : description;
    }

    /// <summary>
    /// Navigates to the create product page.
    /// </summary>
    private void NavigateToCreate()
    {
        Nav.NavigateTo("/product-management/create");
    }

    /// <summary>
    /// Navigates to the edit product page.
    /// </summary>
    /// <param name="id">Product identifier.</param>
    private void NavigateToEdit(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        Nav.NavigateTo($"/product-management/edit/{id}");
    }

    /// <summary>
    /// Navigates to the price management page for a product.
    /// </summary>
    /// <param name="id">Product identifier.</param>
    private void NavigateToPrices(Guid id)
    {
        if (id == Guid.Empty)
        {
            return;
        }

        Nav.NavigateTo($"/product-management/prices/{id}");
    }
}

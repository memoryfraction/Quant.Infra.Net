@page "/product-management/prices/{ProductId:guid}"
@layout MainLayout
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject BlazorTokenService TokenService

@using Saas.Infra.MVC.Models.Requests
@using Saas.Infra.MVC.Models.Responses

<PageTitle>Manage Prices - Saas.Infra</PageTitle>

@if (_isLoading)
{
    <div class="container-fluid py-4">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="container-fluid py-4">
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    </div>
}
else
{
    <div class="container-fluid py-4">
        <div class="row mb-4">
            <div class="col-12">
                <button type="button" class="btn btn-outline-secondary mb-3" @onclick="NavigateBack">
                    <i class="bi bi-arrow-left"></i> Back to Products
                </button>

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="display-6 mb-2">
                            <i class="bi bi-tags"></i> Pricing Plans
                        </h1>
                        <p class="text-muted mb-0">
                            <strong>@_productName</strong> (@_productCode)
                        </p>
                    </div>
                    <div>
                        <button type="button" class="btn btn-primary" @onclick="ShowAddPriceModal">
                            <i class="bi bi-plus-circle"></i> Add Price Plan
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row" id="pricesContainer">
            @if (_prices.Count == 0)
            {
                <div class="col-12">
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                        <h5>No pricing plans yet</h5>
                        <p class="mb-0">Add your first pricing plan to get started.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var price in _prices)
                {
                    <div class="col-md-6 col-lg-4 mb-3">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5 class="card-title mb-0">@price.Name</h5>
                                    @if (price.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </div>

                                <div class="display-6 fw-bold text-primary mb-2">
                                    @price.Currency @((price.Amount / 100.0m).ToString("F2"))
                                </div>

                                <p class="text-muted mb-3">
                                    <i class="bi bi-clock"></i> @price.BillingPeriod
                                </p>

                                <div class="d-grid gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeletePriceAsync(price.Id, price.Name)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                            <div class="card-footer text-muted">
                                <small>ID: @price.Id.ToString().Substring(0, 8)...</small>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@if (_showAddPriceModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-plus-circle"></i> Add Price Plan
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideAddPriceModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="_createPriceForm" OnValidSubmit="HandleAddPriceAsync">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label for="priceName" class="form-label">Plan Name <span class="text-danger">*</span></label>
                            <InputText id="priceName" class="form-control" @bind-Value="_createPriceForm.Name" maxlength="100" />
                        </div>

                        <div class="mb-3">
                            <label for="billingPeriod" class="form-label">Billing Period <span class="text-danger">*</span></label>
                            <select id="billingPeriod" class="form-select" @bind="_createPriceForm.BillingPeriod">
                                <option value="">Select period...</option>
                                <option value="week">Week</option>
                                <option value="month">Month</option>
                                <option value="year">Year</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="amount" class="form-label">Amount (in cents) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <InputNumber id="amount" class="form-control" @bind-Value="_createPriceForm.Amount" />
                                <span class="input-group-text">
                                    
                                    
                                    
                                    
                                    
                                    ¢
                                </span>
                            </div>
                            <div class="form-text">
                                Amount in cents (e.g., 9900 = $99.00)
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="currency" class="form-label">Currency</label>
                            <select id="currency" class="form-select" @bind="_createPriceForm.Currency">
                                <option value="USD">USD</option>
                                <option value="EUR">EUR</option>
                                <option value="GBP">GBP</option>
                                <option value="CNY">CNY</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox id="priceActive" class="form-check-input" @bind-Value="_createPriceForm.IsActive" />
                                <label class="form-check-label" for="priceActive">
                                    Active
                                </label>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(_priceError))
                        {
                            <div class="alert alert-danger" role="alert">@_priceError</div>
                        }
                    </EditForm>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideAddPriceModal">Cancel</button>
                    <button type="button" class="btn btn-primary" disabled="@_isSavingPrice" @onclick="SubmitAddPriceAsync">
                        @if (_isSavingPrice)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span class="ms-2">Adding...</span>
                        }
                        else
                        {
                            <span>
                                <i class="bi bi-check-circle"></i>
                                <span>Add Price</span>
                            </span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .modal-header.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

    .btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .card {
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>

@code {
    /// <summary>
    /// Route parameter for the product identifier.
    /// </summary>
    [Parameter]
    public Guid ProductId { get; set; }

    private readonly List<PriceDto> _prices = new();
    private readonly CreatePriceRequest _createPriceForm = new();
    private string _productName = string.Empty;
    private string _productCode = string.Empty;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _priceError;
    private bool _showAddPriceModal;
    private bool _isSavingPrice;

    /// <summary>
    /// Loads product and price information on initialization.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated || string.IsNullOrWhiteSpace(TokenService.AccessToken))
        {
            Nav.NavigateTo("/account/login?returnUrl=/product-management", forceLoad: true);
            return;
        }

        if (ProductId == Guid.Empty)
        {
            _errorMessage = "Invalid product identifier.";
            _isLoading = false;
            return;
        }

        _createPriceForm.ProductId = ProductId;
        await LoadProductAndPricesAsync().ConfigureAwait(false);
    }

    /// <summary>
    /// Loads product details and associated prices from the backend API.
    /// </summary>
    private async Task LoadProductAndPricesAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _prices.Clear();

        try
        {
            var client = CreateAuthorizedClient();

            var productResponse = await client.GetAsync($"/api/products/{ProductId}").ConfigureAwait(false);
            if (!productResponse.IsSuccessStatusCode)
            {
                if (productResponse.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo("/account/login?returnUrl=/product-management", forceLoad: true);
                    return;
                }

                _errorMessage = "Failed to load product.";
                return;
            }

            var product = await productResponse.Content.ReadFromJsonAsync<ProductDto>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (product == null)
            {
                _errorMessage = "Product not found.";
                return;
            }

            _productName = product.Name ?? string.Empty;
            _productCode = product.Code ?? string.Empty;

            var pricesResponse = await client.GetAsync($"/api/prices/product/{ProductId}").ConfigureAwait(false);
            if (!pricesResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to load prices.";
                return;
            }

            var prices = await pricesResponse.Content.ReadFromJsonAsync<List<PriceDto>>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (prices != null)
            {
                _prices.AddRange(prices.OrderBy(p => p.Amount));
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while loading prices: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Handles adding a new price plan when the form is valid.
    /// </summary>
    private async Task HandleAddPriceAsync()
    {
        _priceError = null;

        if (ProductId == Guid.Empty)
        {
            _priceError = "Invalid product identifier.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_createPriceForm.Name) || string.IsNullOrWhiteSpace(_createPriceForm.BillingPeriod))
        {
            _priceError = "Please fill in all required fields.";
            return;
        }

        _createPriceForm.ProductId = ProductId;
        _isSavingPrice = true;

        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.PostAsJsonAsync("/api/prices", _createPriceForm, new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (!response.IsSuccessStatusCode)
            {
                if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo("/account/login?returnUrl=/product-management", forceLoad: true);
                    return;
                }

                _priceError = "Failed to add price.";
                return;
            }

            _createPriceForm.Name = string.Empty;
            _createPriceForm.BillingPeriod = string.Empty;
            _createPriceForm.Amount = 0;
            _createPriceForm.Currency = "USD";
            _createPriceForm.IsActive = true;

            await LoadProductAndPricesAsync().ConfigureAwait(false);
            _showAddPriceModal = false;
        }
        catch (Exception ex)
        {
            _priceError = $"An error occurred while adding price: {ex.Message}";
        }
        finally
        {
            _isSavingPrice = false;
        }
    }

    /// <summary>
    /// Wrapper to trigger price creation from the footer button.
    /// </summary>
    private Task SubmitAddPriceAsync()
    {
        return HandleAddPriceAsync();
    }

    /// <summary>
    /// Deletes a price via the backend API.
    /// </summary>
    /// <param name="priceId">Price identifier.</param>
    /// <param name="priceName">Price name for display.</param>
    private async Task DeletePriceAsync(Guid priceId, string? priceName)
    {
        if (priceId == Guid.Empty)
        {
            return;
        }

        var confirmMessage = string.IsNullOrWhiteSpace(priceName)
            ? "Are you sure you want to delete this price?"
            : $"Are you sure you want to delete \"{priceName}\"?";

        var confirmed = await ConfirmAsync(confirmMessage).ConfigureAwait(false);
        if (!confirmed)
        {
            return;
        }

        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.DeleteAsync($"/api/prices/{priceId}").ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to delete price.";
                return;
            }

            var existing = _prices.FirstOrDefault(p => p.Id == priceId);
            if (existing != null)
            {
                _prices.Remove(existing);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while deleting price: {ex.Message}";
        }
    }

    /// <summary>
    /// Simple confirmation wrapper so the logic stays in C#.
    /// </summary>
    /// <param name="message">Confirmation message.</param>
    /// <returns>Always returns true currently.</returns>
    private Task<bool> ConfirmAsync(string message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return Task.FromResult(false);
        }

        return Task.FromResult(true);
    }

    /// <summary>
    /// Shows the add price modal.
    /// </summary>
    private void ShowAddPriceModal()
    {
        _priceError = null;
        _showAddPriceModal = true;
    }

    /// <summary>
    /// Hides the add price modal.
    /// </summary>
    private void HideAddPriceModal()
    {
        _priceError = null;
        _showAddPriceModal = false;
    }

    /// <summary>
    /// Creates an authorized HTTP client for API calls.
    /// </summary>
    /// <returns>Configured HTTP client.</returns>
    private HttpClient CreateAuthorizedClient()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? Nav.BaseUri.TrimEnd('/');
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(apiBaseUrl);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenService.AccessToken);

        return client;
    }

    /// <summary>
    /// Navigates back to the product management list.
    /// </summary>
    private void NavigateBack()
    {
        Nav.NavigateTo("/product-management");
    }
}

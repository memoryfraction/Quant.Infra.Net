@page "/subscriptions/{Id:guid}"
@layout MainLayout
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject BlazorTokenService TokenService

@using Saas.Infra.MVC.Models.Responses

<PageTitle>Subscription Details - Saas.Infra</PageTitle>

@if (_isLoading)
{
    <div class="container py-5">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading subscription details...</p>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="container py-5">
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    </div>
}
else if (_subscription is null)
{
    <div class="container py-5">
        <div class="alert alert-warning" role="alert">Subscription was not found.</div>
    </div>
}
else
{
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <button type="button" class="btn btn-outline-secondary" @onclick="NavigateBack">
                <i class="bi bi-arrow-left"></i> Back to Subscriptions
            </button>
            @if (_subscription.Status == 1)
            {
                <button type="button" class="btn btn-outline-danger" @onclick="ShowCancelConfirmation">
                    <i class="bi bi-x-circle"></i> Cancel Subscription
                </button>
            }
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h4 class="mb-0">Subscription Summary</h4>
                    </div>
                    <div class="card-body">
                        <h3 class="mb-2">@(_subscription.ProductName ?? "Product")</h3>
                        <p class="text-muted mb-3">@(_subscription.PriceName ?? "Plan")</p>

                        <div class="mb-3">
                            <span class="badge @GetStatusBadgeCss(_subscription.Status)">@GetStatusText(_subscription.Status)</span>
                        </div>

                        <dl class="row mb-0">
                            <dt class="col-sm-5">Subscription ID</dt>
                            <dd class="col-sm-7"><code>@_subscription.Id</code></dd>

                            <dt class="col-sm-5">Amount</dt>
                            <dd class="col-sm-7">@_subscription.FormattedAmount</dd>

                            <dt class="col-sm-5">Auto Renew</dt>
                            <dd class="col-sm-7">@(_subscription.AutoRenew ? "Enabled" : "Disabled")</dd>

                            <dt class="col-sm-5">Start Date</dt>
                            <dd class="col-sm-7">@_subscription.StartDate.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</dd>

                            <dt class="col-sm-5">End Date</dt>
                            <dd class="col-sm-7">@(_subscription.EndDate?.LocalDateTime.ToString("yyyy-MM-dd HH:mm") ?? "-")</dd>

                            @if (_subscription.RemainingDays.HasValue)
                            {
                                <dt class="col-sm-5">Remaining Days</dt>
                                <dd class="col-sm-7">@_subscription.RemainingDays.Value</dd>
                            }
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h4 class="mb-0">Payment History</h4>
                    </div>
                    <div class="card-body p-0">
                        @if (_transactions.Count == 0)
                        {
                            <div class="p-4 text-center text-muted">No transactions were found for this subscription.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Created</th>
                                            <th>Amount</th>
                                            <th>Gateway</th>
                                            <th>Status</th>
                                            <th>External ID</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var transaction in _transactions)
                                        {
                                            <tr>
                                                <td>@transaction.CreatedTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                                <td>@transaction.Currency @((transaction.Amount / 100.0m).ToString("F2"))</td>
                                                <td>@transaction.Gateway</td>
                                                <td><span class="badge @GetTransactionStatusBadgeCss(transaction.Status)">@transaction.StatusText</span></td>
                                                <td><small>@(transaction.ExternalTransactionId ?? "-")</small></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (_showCancelConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Cancel Subscription</h5>
                    <button type="button" class="btn-close" @onclick="HideCancelConfirmation"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Are you sure you want to cancel this subscription?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideCancelConfirmation">Keep Subscription</button>
                    <button type="button" class="btn btn-danger" disabled="@_isCancelling" @onclick="CancelSubscriptionAsync">
                        @if (_isCancelling)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                            <span class="ms-2">Cancelling...</span>
                        }
                        else
                        {
                            <span>Confirm Cancel</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// 订阅ID路由参数。
    /// Subscription ID route parameter.
    /// </summary>
    [Parameter]
    public Guid Id { get; set; }

    private SubscriptionDto? _subscription;
    private readonly List<SubscriptionTransactionItem> _transactions = new();
    private bool _isLoading = true;
    private bool _showCancelConfirmation;
    private bool _isCancelling;
    private string? _errorMessage;

    /// <summary>
    /// 加载订阅详情和支付历史。
    /// Loads the subscription details and payment history.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!TokenService.IsAuthenticated || string.IsNullOrWhiteSpace(TokenService.AccessToken))
        {
            Nav.NavigateTo($"/account/login?returnUrl={Uri.EscapeDataString($"/subscriptions/{Id}")}", forceLoad: true);
            return;
        }

        if (Id == Guid.Empty)
        {
            _errorMessage = "Invalid subscription identifier.";
            _isLoading = false;
            return;
        }

        await LoadSubscriptionDetailsAsync().ConfigureAwait(false);
    }

    private async Task LoadSubscriptionDetailsAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _transactions.Clear();

        try
        {
            var client = CreateAuthorizedClient();

            var subscriptionResponse = await client.GetAsync($"/api/subscriptions/{Id}").ConfigureAwait(false);
            if (!subscriptionResponse.IsSuccessStatusCode)
            {
                if (subscriptionResponse.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo($"/account/login?returnUrl={Uri.EscapeDataString($"/subscriptions/{Id}")}", forceLoad: true);
                    return;
                }

                _errorMessage = "Failed to load the subscription details.";
                return;
            }

            _subscription = await subscriptionResponse.Content.ReadFromJsonAsync<SubscriptionDto>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (_subscription == null)
            {
                _errorMessage = "Subscription was not found.";
                return;
            }

            var transactionsResponse = await client.GetAsync($"/api/subscriptions/{Id}/transactions").ConfigureAwait(false);
            if (!transactionsResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to load the payment history.";
                return;
            }

            var transactions = await transactionsResponse.Content.ReadFromJsonAsync<List<SubscriptionTransactionItem>>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }).ConfigureAwait(false);

            if (transactions != null)
            {
                _transactions.AddRange(transactions);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while loading the subscription details: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowCancelConfirmation()
    {
        _showCancelConfirmation = true;
    }

    private void HideCancelConfirmation()
    {
        _showCancelConfirmation = false;
    }

    private async Task CancelSubscriptionAsync()
    {
        if (Id == Guid.Empty)
        {
            _errorMessage = "Invalid subscription identifier.";
            return;
        }

        _isCancelling = true;
        _errorMessage = null;

        try
        {
            var client = CreateAuthorizedClient();
            var response = await client.PostAsync($"/api/subscriptions/{Id}/cancel", null).ConfigureAwait(false);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to cancel the subscription.";
                return;
            }

            _showCancelConfirmation = false;
            await LoadSubscriptionDetailsAsync().ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while cancelling the subscription: {ex.Message}";
        }
        finally
        {
            _isCancelling = false;
        }
    }

    private void NavigateBack()
    {
        Nav.NavigateTo("/subscriptions");
    }

    private HttpClient CreateAuthorizedClient()
    {
        var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? Nav.BaseUri.TrimEnd('/');
        var client = HttpClientFactory.CreateClient();
        client.BaseAddress = new Uri(apiBaseUrl);
        client.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenService.AccessToken);

        return client;
    }

    private static string GetStatusText(short status) => status switch
    {
        0 => "Pending",
        1 => "Active",
        2 => "Cancelled",
        3 => "Expired",
        _ => "Unknown"
    };

    private static string GetStatusBadgeCss(short status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-success",
        2 => "bg-secondary",
        3 => "bg-dark",
        _ => "bg-light text-dark"
    };

    private static string GetTransactionStatusBadgeCss(short status) => status switch
    {
        0 => "bg-warning text-dark",
        1 => "bg-success",
        2 => "bg-danger",
        3 => "bg-info text-dark",
        _ => "bg-light text-dark"
    };

    private sealed class SubscriptionTransactionItem
    {
        public Guid Id { get; set; }

        public long Amount { get; set; }

        public string Currency { get; set; } = string.Empty;

        public string Gateway { get; set; } = string.Empty;

        public short Status { get; set; }

        public string StatusText { get; set; } = string.Empty;

        public string? ExternalTransactionId { get; set; }

        public DateTimeOffset CreatedTime { get; set; }

        public string? Remarks { get; set; }
    }
}

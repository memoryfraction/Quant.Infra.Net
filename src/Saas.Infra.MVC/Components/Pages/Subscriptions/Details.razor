@page "/subscriptions/{Id:guid}"
@layout MainLayout
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject Saas.Infra.MVC.Services.Blazor.BlazorTokenService TokenService

@using Saas.Infra.MVC.Models.Responses

<PageTitle>Subscription Details - Saas.Infra</PageTitle>

@if (_isLoading)
{
    <div class="container py-5">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading subscription details...</p>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="container py-5">
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
        <a class="btn btn-outline-secondary mt-3" href="/subscriptions">Back to Subscriptions</a>
    </div>
}
else if (_subscription == null)
{
    <div class="container py-5">
        <div class="alert alert-warning" role="alert">Subscription was not found.</div>
        <a class="btn btn-outline-secondary mt-3" href="/subscriptions">Back to Subscriptions</a>
    </div>
}
else
{
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Subscription Details</h1>
            <a class="btn btn-outline-secondary" href="/subscriptions">Back to Subscriptions</a>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div><strong>Subscription ID:</strong> <code>@_subscription.Id</code></div>
                        <div><strong>Product:</strong> @(_subscription.ProductName ?? "-")</div>
                        <div><strong>Plan:</strong> @(_subscription.PriceName ?? "-") (@(_subscription.BillingPeriod ?? "-"))</div>
                        <div><strong>Status:</strong> <span class="@GetStatusClass(_subscription.Status)">@_subscription.StatusText</span></div>
                    </div>
                    <div class="col-md-6">
                        <div><strong>Amount:</strong> @_subscription.FormattedAmount</div>
                        <div><strong>Auto Renew:</strong> @(_subscription.AutoRenew ? "Yes" : "No")</div>
                        <div><strong>Start:</strong> @_subscription.StartDate.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</div>
                        <div><strong>End:</strong> @(_subscription.EndDate?.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h2 class="h5 mb-0">Transactions</h2>
            </div>
            <div class="card-body">
                @if (_transactions.Count == 0)
                {
                    <div class="text-muted">No transactions found for this subscription.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Created</th>
                                    <th>Amount</th>
                                    <th>Gateway</th>
                                    <th>Status</th>
                                    <th>External ID</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tx in _transactions)
                                {
                                    <tr>
                                        <td>@tx.CreatedTime.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        <td>@tx.Currency @((tx.Amount / 100.0m).ToString("F2"))</td>
                                        <td>@tx.Gateway</td>
                                        <td>@tx.StatusText</td>
                                        <td><code>@(tx.ExternalTransactionId ?? "-")</code></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _isLoading = true;
    private string? _errorMessage;
    private SubscriptionDto? _subscription;
    private readonly List<SubscriptionTransactionDto> _transactions = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id == Guid.Empty)
        {
            _errorMessage = "Invalid subscription ID.";
            _isLoading = false;
            return;
        }

        if (!TokenService.IsAuthenticated || string.IsNullOrWhiteSpace(TokenService.AccessToken))
        {
            Nav.NavigateTo($"/account/login?returnUrl=/subscriptions/{Id}", forceLoad: true);
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _transactions.Clear();

        try
        {
            var apiBaseUrl = Configuration["ApiSettings:BaseUrl"] ?? Nav.BaseUri.TrimEnd('/');
            var client = HttpClientFactory.CreateClient();
            client.BaseAddress = new Uri(apiBaseUrl);
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", TokenService.AccessToken);

            var subResp = await client.GetAsync($"/api/subscriptions/{Id}");
            if (!subResp.IsSuccessStatusCode)
            {
                if (subResp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    TokenService.ClearToken();
                    Nav.NavigateTo($"/account/login?returnUrl=/subscriptions/{Id}", forceLoad: true);
                    return;
                }

                if (subResp.StatusCode == System.Net.HttpStatusCode.Forbidden || subResp.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    _errorMessage = "Subscription was not found or you do not have access.";
                    return;
                }

                _errorMessage = "Failed to load subscription details.";
                return;
            }

            _subscription = await subResp.Content.ReadFromJsonAsync<SubscriptionDto>(new System.Text.Json.JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            var txResp = await client.GetAsync($"/api/subscriptions/{Id}/transactions");
            if (txResp.IsSuccessStatusCode)
            {
                var items = await txResp.Content.ReadFromJsonAsync<List<SubscriptionTransactionDto>>(new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

                if (items != null)
                {
                    _transactions.AddRange(items);
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred while loading details: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusClass(short status)
    {
        return status switch
        {
            0 => "badge bg-warning text-dark",
            1 => "badge bg-success",
            2 => "badge bg-secondary",
            3 => "badge bg-dark",
            _ => "badge bg-light text-dark"
        };
    }

    private sealed class SubscriptionTransactionDto
    {
        public Guid Id { get; set; }
        public long Amount { get; set; }
        public string Currency { get; set; } = "USD";
        public string Gateway { get; set; } = string.Empty;
        public short Status { get; set; }
        public string StatusText { get; set; } = string.Empty;
        public string? ExternalTransactionId { get; set; }
        public DateTimeOffset CreatedTime { get; set; }
    }
}

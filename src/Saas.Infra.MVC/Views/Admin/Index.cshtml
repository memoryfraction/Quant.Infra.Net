@model Saas.Infra.MVC.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard - Saas.Infra";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-6"><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
            <p class="text-muted">Overview of products, subscriptions and payments.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Products</h6>
                    <div class="d-flex justify-content-between align-items-end">
                        <h2 class="mb-0">@Model.TotalProducts</h2>
                        <span class="badge bg-success">Active: @Model.ActiveProducts</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Subscriptions</h6>
                    <div class="d-flex justify-content-between align-items-end">
                        <h2 class="mb-0">@Model.TotalSubscriptions</h2>
                        <span class="badge bg-primary">Active: @Model.ActiveSubscriptions</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Transactions</h6>
                    <div class="d-flex justify-content-between align-items-end">
                        <h2 class="mb-0">@Model.TotalTransactions</h2>
                        <span class="badge bg-info text-dark">Success: @Model.SuccessfulTransactions</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <a href="@Url.Action("Index", "ProductManagement")" class="card text-decoration-none shadow-sm h-100">
                <div class="card-body">
                    <h5><i class="bi bi-box-seam"></i> Product Management</h5>
                    <p class="text-muted mb-0">Create and manage product definitions and pricing.</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@Url.Action("Subscriptions", "Admin")" class="card text-decoration-none shadow-sm h-100">
                <div class="card-body">
                    <h5><i class="bi bi-list-check"></i> Subscription Management</h5>
                    <p class="text-muted mb-0">View all user subscriptions and status.</p>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a href="@Url.Action("Transactions", "Admin")" class="card text-decoration-none shadow-sm h-100">
                <div class="card-body">
                    <h5><i class="bi bi-cash-coin"></i> Transaction Monitoring</h5>
                    <p class="text-muted mb-0">Filter and review payment transactions.</p>
                </div>
            </a>
        </div>
    </div>
</div>

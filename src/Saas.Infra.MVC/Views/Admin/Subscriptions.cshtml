@model Saas.Infra.MVC.Models.AdminSubscriptionsPageViewModel

@{
    ViewData["Title"] = "Admin Subscriptions - Saas.Infra";
    Layout = "_Layout";

    string StatusText(short status)
    {
        return status switch
        {
            0 => "Pending",
            1 => "Active",
            2 => "Cancelled",
            3 => "Expired",
            _ => "Unknown"
        };
    }

    string StatusBadge(short status)
    {
        return status switch
        {
            0 => "bg-warning text-dark",
            1 => "bg-success",
            2 => "bg-secondary",
            3 => "bg-dark",
            _ => "bg-light text-dark"
        };
    }
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><i class="bi bi-list-check"></i> Subscription Management</h1>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Admin")">
            <i class="bi bi-arrow-left"></i> Back to Admin
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="Subscriptions" asp-controller="Admin" class="row g-2">
                <div class="col-md-6">
                    <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="Search by user/email/product..." />
                </div>
                <div class="col-md-3">
                    <select class="form-select" name="status">
                        <option value="">All Status</option>
                        <option value="0" selected="@(Model.Status == 0)">Pending</option>
                        <option value="1" selected="@(Model.Status == 1)">Active</option>
                        <option value="2" selected="@(Model.Status == 2)">Cancelled</option>
                        <option value="3" selected="@(Model.Status == 3)">Expired</option>
                    </select>
                </div>
                <div class="col-md-3 d-grid">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i> Filter</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Items != null && Model.Items.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Product</th>
                                <th>Plan</th>
                                <th>Status</th>
                                <th>Auto Renew</th>
                                <th>Created</th>
                                <th>ID</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.UserName</div>
                                    <small class="text-muted">@item.UserEmail</small>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.ProductName</div>
                                    <small class="text-muted">@item.ProductCode</small>
                                </td>
                                <td>@item.PriceName</td>
                                <td><span class="badge @StatusBadge(item.Status)">@StatusText(item.Status)</span></td>
                                <td>@(item.AutoRenew ? "Yes" : "No")</td>
                                <td>@item.CreatedTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><code>@item.Id.ToString()[..8]</code></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted">No subscriptions found.</div>
            }
        </div>
    </div>
</div>

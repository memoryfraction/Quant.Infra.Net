@model Saas.Infra.MVC.Models.AdminTransactionsPageViewModel

@{
    ViewData["Title"] = "Admin Transactions - Saas.Infra";
    Layout = "_Layout";

    string StatusText(short status)
    {
        return status switch
        {
            0 => "Pending",
            1 => "Success",
            2 => "Failed",
            3 => "Refunded",
            _ => "Unknown"
        };
    }

    string StatusBadge(short status)
    {
        return status switch
        {
            0 => "bg-warning text-dark",
            1 => "bg-success",
            2 => "bg-danger",
            3 => "bg-info text-dark",
            _ => "bg-light text-dark"
        };
    }
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0"><i class="bi bi-cash-coin"></i> Transaction Monitoring</h1>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Admin")">
            <i class="bi bi-arrow-left"></i> Back to Admin
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" asp-action="Transactions" asp-controller="Admin" class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="gateway" value="@Model.Gateway" class="form-control" placeholder="Gateway e.g. Stripe" />
                </div>
                <div class="col-md-4">
                    <select class="form-select" name="status">
                        <option value="">All Status</option>
                        <option value="0" selected="@(Model.Status == 0)">Pending</option>
                        <option value="1" selected="@(Model.Status == 1)">Success</option>
                        <option value="2" selected="@(Model.Status == 2)">Failed</option>
                        <option value="3" selected="@(Model.Status == 3)">Refunded</option>
                    </select>
                </div>
                <div class="col-md-4 d-grid">
                    <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i> Filter</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Items != null && Model.Items.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>User</th>
                                <th>Amount</th>
                                <th>Gateway</th>
                                <th>Status</th>
                                <th>External ID</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.UserName</div>
                                    <small class="text-muted">@item.UserEmail</small>
                                </td>
                                <td>@item.Currency @((item.Amount / 100.0m).ToString("F2"))</td>
                                <td>@item.Gateway</td>
                                <td><span class="badge @StatusBadge(item.Status)">@StatusText(item.Status)</span></td>
                                <td><small>@(item.ExternalTransactionId ?? "-")</small></td>
                                <td>@item.CreatedTime.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted">No transactions found.</div>
            }
        </div>
    </div>
</div>

@model Saas.Infra.Data.PriceEntity

@{
    ViewData["Title"] = "Checkout - Saas.Infra";
    Layout = "_Layout";
    var formattedAmount = (Model.Amount / 100.0).ToString("F2");
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- 返回按钮 -->
            <div class="mb-4">
                <a href="@Url.Action("Details", "Products", new { id = Model.ProductId })" 
                   class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Product
                </a>
            </div>

            <!-- 订单摘要 -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-cart-check"></i> Order Summary
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h5 class="mb-2">@(Model.Product?.Name ?? "Product")</h5>
                            <p class="text-muted mb-1">@Model.Name</p>
                            <small class="text-muted">Billing Period: @Model.BillingPeriod</small>
                        </div>
                        <div class="col-md-4 text-end">
                            <div class="display-6 fw-bold text-primary">
                                @Model.Currency @formattedAmount
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 支付表单 -->
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="bi bi-credit-card"></i> Payment Information
                    </h4>
                </div>
                <div class="card-body">
                    <div id="loading" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-3">Initializing payment...</p>
                    </div>

                    <div id="payment-form" style="display: none;">
                        <!-- Stripe Elements 会插入到这里 -->
                        <div id="payment-element" class="mb-3"></div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-shield-check"></i>
                            <small>Your payment is secured by Stripe. We never store your card details.</small>
                        </div>

                        <div id="payment-error" class="alert alert-danger" style="display: none;" role="alert"></div>

                        <div class="d-grid">
                            <button id="submit-button" class="btn btn-primary btn-lg" type="button">
                                <span id="button-text">Pay @Model.Currency @formattedAmount</span>
                                <span id="spinner" class="spinner-border spinner-border-sm" style="display: none;" role="status"></span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 安全提示 -->
            <div class="text-center mt-4">
                <small class="text-muted">
                    <i class="bi bi-lock-fill"></i> Secure payment powered by Stripe
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        const stripe = Stripe('@ViewBag.StripePublishableKey');
        const priceId = '@Model.Id';
        let elements;

        async function initialize() {
            try {
                // 获取访问令牌
                const token = sessionStorage.getItem('AccessToken') || 
                              getCookie('AccessToken');

                if (!token) {
                    showError('Authentication required. Please login.');
                    setTimeout(() => window.location.href = '/account/login', 2000);
                    return;
                }

                // 创建支付意图
                const response = await fetch('/api/payment/create-intent', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        priceId: priceId,
                        gateway: 'Stripe'
                    })
                });

                if (!response.ok) {
                    const error = await response.json();
                    throw new Error(error.message || 'Failed to create payment intent');
                }

                const { clientSecret } = await response.json();

                // 初始化 Stripe Elements
                const appearance = {
                    theme: 'stripe',
                    variables: {
                        colorPrimary: '#667eea',
                    }
                };

                elements = stripe.elements({ clientSecret, appearance });
                const paymentElement = elements.create('payment');
                paymentElement.mount('#payment-element');

                // 隐藏加载状态，显示表单
                document.getElementById('loading').style.display = 'none';
                document.getElementById('payment-form').style.display = 'block';

            } catch (error) {
                console.error('Initialization error:', error);
                showError(error.message);
            }
        }

        document.getElementById('submit-button')?.addEventListener('click', async () => {
            const submitButton = document.getElementById('submit-button');
            const buttonText = document.getElementById('button-text');
            const spinner = document.getElementById('spinner');

            // 禁用按钮并显示加载状态
            submitButton.disabled = true;
            buttonText.style.display = 'none';
            spinner.style.display = 'inline-block';

            try {
                const { error } = await stripe.confirmPayment({
                    elements,
                    confirmParams: {
                        return_url: `${window.location.origin}/checkout/success?priceId=${priceId}`,
                    },
                });

                if (error) {
                    showError(error.message);
                    submitButton.disabled = false;
                    buttonText.style.display = 'inline';
                    spinner.style.display = 'none';
                }
            } catch (err) {
                showError('Payment processing failed. Please try again.');
                submitButton.disabled = false;
                buttonText.style.display = 'inline';
                spinner.style.display = 'none';
            }
        });

        function showError(message) {
            const errorDiv = document.getElementById('payment-error');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';
        }

        function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
            return null;
        }

        // 页面加载时初始化
        initialize();
    </script>
}

<style>
    .card-header.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }

    #payment-element {
        padding: 1rem;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 0.75rem 1.5rem;
    }

    .btn-primary:hover:not(:disabled) {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .btn-primary:disabled {
        opacity: 0.65;
    }
</style>

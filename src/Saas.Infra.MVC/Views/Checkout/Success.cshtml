@{
    ViewData["Title"] = "Payment Success - Saas.Infra";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm text-center">
                <div class="card-body p-5">
                    <!-- 成功图标 -->
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>

                    <!-- 成功消息 -->
                    @if (ViewBag.IsSubscriptionCreated == true)
                    {
                        <h2 class="mb-3">Payment Successful!</h2>
                        <p class="lead text-muted mb-4">
                            Thank you for your subscription. Your payment and subscription are completed.
                        </p>
                    }
                    else
                    {
                        <h2 class="mb-3">Payment Received</h2>
                        <p class="lead text-muted mb-4">
                            Your payment is received, but subscription activation is still pending.
                        </p>
                    }

                    <!-- 订阅ID（如果有） -->
                    @if (ViewBag.SubscriptionId != null)
                    {
                        <div class="alert alert-info" role="alert">
                            <small>Subscription ID: <strong>@ViewBag.SubscriptionId</strong></small>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning" role="alert">
                            <small>No subscription ID is available yet. Please contact support if this status does not change.</small>
                        </div>
                    }

                    <!-- 操作按钮 -->
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Index", "Subscriptions")" class="btn btn-primary btn-lg">
                            <i class="bi bi-list-check"></i> View My Subscriptions
                        </a>
                        <a href="@Url.Action("Index", "Products")" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Browse More Products
                        </a>
                    </div>

                    <!-- 支持信息 -->
                    <div class="mt-4">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i> 
                            You will receive a confirmation email shortly.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .card {
        border: none;
        animation: fadeInUp 0.5s ease-in-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@model Saas.Infra.Data.ProductEntity

@{
    ViewData["Title"] = $"Manage Prices - {Model.Name}";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <a href="@Url.Action("Index", "ProductManagement")" class="btn btn-outline-secondary mb-3">
                <i class="bi bi-arrow-left"></i> Back to Products
            </a>
            
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-6 mb-2">
                        <i class="bi bi-tags"></i> Pricing Plans
                    </h1>
                    <p class="text-muted mb-0">
                        <strong>@Model.Name</strong> (@Model.Code)
                    </p>
                </div>
                <div>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPriceModal">
                        <i class="bi bi-plus-circle"></i> Add Price Plan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 价格列表 -->
    <div class="row" id="pricesContainer">
        <div class="col-12">
            <div id="loading" class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 添加价格 Modal -->
<div class="modal fade" id="addPriceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i> Add Price Plan
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addPriceForm">
                    <div class="mb-3">
                        <label for="priceName" class="form-label">Plan Name <span class="text-danger">*</span></label>
                        <input type="text" 
                               class="form-control" 
                               id="priceName" 
                               required
                               placeholder="e.g., Monthly Plan"
                               maxlength="100">
                    </div>

                    <div class="mb-3">
                        <label for="billingPeriod" class="form-label">Billing Period <span class="text-danger">*</span></label>
                        <select class="form-select" id="billingPeriod" required>
                            <option value="">Select period...</option>
                            <option value="week">Week</option>
                            <option value="month">Month</option>
                            <option value="year">Year</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="amount" class="form-label">Amount (in cents) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input type="number" 
                                   class="form-control" 
                                   id="amount" 
                                   required
                                   min="0"
                                   placeholder="9900"
                                   step="1">
                            <span class="input-group-text">¢</span>
                        </div>
                        <div class="form-text">
                            Amount in cents (e.g., 9900 = $99.00)
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="currency" class="form-label">Currency</label>
                        <select class="form-select" id="currency">
                            <option value="USD" selected>USD</option>
                            <option value="EUR">EUR</option>
                            <option value="GBP">GBP</option>
                            <option value="CNY">CNY</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" 
                                   type="checkbox" 
                                   id="priceActive"
                                   checked>
                            <label class="form-check-label" for="priceActive">
                                Active
                            </label>
                        </div>
                    </div>

                    <div id="priceError" class="alert alert-danger" style="display: none;"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addPrice()">
                    <i class="bi bi-check-circle"></i> Add Price
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const productId = '@Model.Id';

        async function loadPrices() {
            const loading = document.getElementById('loading');
            const container = document.getElementById('pricesContainer');

            try {
                const token = getAccessToken();
                const response = await fetch(`/api/prices/product/${productId}`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (!response.ok) {
                    throw new Error('Failed to load prices');
                }

                const prices = await response.json();
                loading.style.display = 'none';

                if (prices.length === 0) {
                    container.innerHTML = `
                        <div class="col-12">
                            <div class="alert alert-info text-center">
                                <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                                <h5>No pricing plans yet</h5>
                                <p class="mb-0">Add your first pricing plan to get started.</p>
                            </div>
                        </div>
                    `;
                } else {
                    container.innerHTML = prices.map(price => createPriceCard(price)).join('');
                }
            } catch (error) {
                console.error('Error loading prices:', error);
                loading.style.display = 'none';
                container.innerHTML = `
                    <div class="col-12">
                        <div class="alert alert-danger">Failed to load prices. Please try again.</div>
                    </div>
                `;
            }
        }

        function createPriceCard(price) {
            const formattedAmount = (price.amount / 100).toFixed(2);
            const statusBadge = price.isActive ? 
                '<span class="badge bg-success">Active</span>' : 
                '<span class="badge bg-secondary">Inactive</span>';

            return `
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title mb-0">${price.name}</h5>
                                ${statusBadge}
                            </div>
                            
                            <div class="display-6 fw-bold text-primary mb-2">
                                ${price.currency} ${formattedAmount}
                            </div>
                            
                            <p class="text-muted mb-3">
                                <i class="bi bi-clock"></i> ${price.billingPeriod}
                            </p>
                            
                            <div class="d-grid gap-2">
                                <button class="btn btn-sm btn-outline-danger" onclick="deletePrice('${price.id}', '${price.name}')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                        <div class="card-footer text-muted">
                            <small>ID: ${price.id.substring(0, 8)}...</small>
                        </div>
                    </div>
                </div>
            `;
        }

        async function addPrice() {
            const errorDiv = document.getElementById('priceError');
            errorDiv.style.display = 'none';

            const formData = {
                productId: productId,
                name: document.getElementById('priceName').value.trim(),
                billingPeriod: document.getElementById('billingPeriod').value,
                amount: parseInt(document.getElementById('amount').value),
                currency: document.getElementById('currency').value,
                isActive: document.getElementById('priceActive').checked
            };

            if (!formData.name || !formData.billingPeriod || !formData.amount) {
                errorDiv.textContent = 'Please fill in all required fields';
                errorDiv.style.display = 'block';
                return;
            }

            try {
                const token = getAccessToken();
                const response = await fetch('/api/prices', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(formData)
                });

                if (!response.ok) {
                    const error = await response.json();
                    throw new Error(error.message || 'Failed to add price');
                }

                // 关闭 modal
                bootstrap.Modal.getInstance(document.getElementById('addPriceModal')).hide();
                
                // 重置表单
                document.getElementById('addPriceForm').reset();
                
                // 重新加载价格列表
                await loadPrices();
                
                alert('Price plan added successfully!');
            } catch (error) {
                console.error('Error adding price:', error);
                errorDiv.textContent = error.message;
                errorDiv.style.display = 'block';
            }
        }

        async function deletePrice(priceId, priceName) {
            if (!confirm(`Are you sure you want to delete "${priceName}"?`)) {
                return;
            }

            try {
                const token = getAccessToken();
                const response = await fetch(`/api/prices/${priceId}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                if (!response.ok) {
                    throw new Error('Failed to delete price');
                }

                alert('Price deleted successfully');
                await loadPrices();
            } catch (error) {
                console.error('Error deleting price:', error);
                alert('Failed to delete price. Please try again.');
            }
        }

        function getAccessToken() {
            return sessionStorage.getItem('AccessToken') || getCookie('AccessToken');
        }

        function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
            return null;
        }

        // 页面加载时获取价格
        document.addEventListener('DOMContentLoaded', loadPrices);
    </script>
}

<style>
    .modal-header.bg-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .card {
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>

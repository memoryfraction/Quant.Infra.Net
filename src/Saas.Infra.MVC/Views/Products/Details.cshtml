@model Saas.Infra.Data.ProductEntity

@{
    ViewData["Title"] = $"{Model.Name} - Saas.Infra";
    Layout = "_Layout";
}

<div class="container py-5">
    <!-- 返回按钮 -->
    <div class="mb-4">
        <a href="@Url.Action("Index", "Products")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Products
        </a>
    </div>

    <!-- 产品信息 -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div>
                            <h1 class="display-5 mb-2">@Model.Name</h1>
                            <p class="text-muted mb-0">
                                <i class="bi bi-tag"></i> @Model.Code
                            </p>
                        </div>
                        <span class="badge bg-success fs-6">Active</span>
                    </div>
                    
                    <p class="lead">@(Model.Description ?? "No description available")</p>

                    @if (!string.IsNullOrEmpty(Model.Metadata))
                    {
                        <div class="alert alert-info mt-3" role="alert">
                            <i class="bi bi-info-circle"></i> 
                            <strong>Features:</strong> This product includes advanced features and capabilities.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 价格方案 -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-4">Choose Your Plan</h2>
        </div>
    </div>

    <div class="row g-4">
        @if (Model.Prices != null && Model.Prices.Any())
        {
            @foreach (var price in Model.Prices.OrderBy(p => p.Amount))
            {
                var formattedAmount = (price.Amount / 100.0).ToString("F2");
                var periodText = price.BillingPeriod switch
                {
                    "week" => "per week",
                    "month" => "per month",
                    "year" => "per year",
                    _ => price.BillingPeriod
                };

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm pricing-card">
                        <div class="card-body d-flex flex-column text-center">
                            <h5 class="card-title mb-3">@price.Name</h5>
                            
                            <div class="mb-4">
                                <div class="display-4 fw-bold">
                                    @price.Currency @formattedAmount
                                </div>
                                <small class="text-muted">@periodText</small>
                            </div>

                            <ul class="list-unstyled text-start mb-4 flex-grow-1">
                                <li class="mb-2">
                                    <i class="bi bi-check-circle-fill text-success"></i> 
                                    Full product access
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-check-circle-fill text-success"></i> 
                                    24/7 Support
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-check-circle-fill text-success"></i> 
                                    Regular updates
                                </li>
                            </ul>

                            <div class="d-grid">
                                <a href="@Url.Action("Index", "Checkout", new { priceId = price.Id })" 
                                   class="btn btn-primary btn-lg">
                                    Subscribe Now
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning text-center" role="alert">
                    <i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>
                    <h5>No pricing plans available</h5>
                    <p class="mb-0">Please contact support for custom pricing.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .pricing-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: 2px solid #e9ecef;
    }

    .pricing-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
        border-color: #667eea;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 0.75rem 1.5rem;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
    }

    .display-4 {
        color: #667eea;
    }

    .bi-check-circle-fill {
        margin-right: 0.5rem;
    }
</style>

@{
    ViewData["Title"] = "期权链查询";
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-7xl mx-auto">
        <!-- 返回按钮 -->
        <div class="mb-4">
            <a href="@Url.Action("Index", "Schwab")" class="inline-flex items-center text-gray-600 hover:text-gray-900">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                返回嘉信理财主页
            </a>
        </div>

        <!-- 页面标题 -->
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">期权链查询</h1>
            <p class="text-gray-600">查看完整期权链、Greeks 和隐含波动率</p>
        </div>

        <!-- 搜索和筛选 -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="md:col-span-2">
                    <label for="optionSymbol" class="block text-sm font-medium text-gray-700 mb-2">股票代码</label>
                    <input type="text" 
                           id="optionSymbol" 
                           placeholder="例如：AAPL, TSLA" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent uppercase"
                           onkeypress="if(event.key === 'Enter') searchOptionChain()">
                </div>
                <div>
                    <label for="contractType" class="block text-sm font-medium text-gray-700 mb-2">合约类型</label>
                    <select id="contractType" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500">
                        <option value="ALL">全部</option>
                        <option value="CALL">看涨期权 (CALL)</option>
                        <option value="PUT">看跌期权 (PUT)</option>
                    </select>
                </div>
                <div class="flex items-end">
                    <button onclick="searchOptionChain()" 
                            class="w-full px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2">
                        查询期权链
                    </button>
                </div>
            </div>
        </div>

        <!-- 加载状态 -->
        <div id="optionLoadingState" class="hidden bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
            <div class="flex items-center">
                <svg class="animate-spin h-5 w-5 text-green-600 mr-3" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-green-700">正在加载期权链数据...</span>
            </div>
        </div>

        <!-- 错误提示 -->
        <div id="optionErrorState" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex">
                <svg class="h-5 w-5 text-red-400 mr-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                </svg>
                <span id="optionErrorMessage" class="text-red-700"></span>
            </div>
        </div>

        <!-- 期权链结果 -->
        <div id="optionChainResult" class="hidden">
            <!-- 标的股票信息 -->
            <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">标的股票信息</h3>
                <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                    <div>
                        <div class="text-sm text-gray-600">股票代码</div>
                        <div id="underlyingSymbol" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">当前价格</div>
                        <div id="underlyingPrice" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">涨跌额</div>
                        <div id="underlyingChange" class="text-lg font-semibold"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">涨跌幅</div>
                        <div id="underlyingChangePercent" class="text-lg font-semibold"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">成交量</div>
                        <div id="underlyingVolume" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                </div>
            </div>

            <!-- 期权链表格 -->
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">到期日</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">行权价</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">类型</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">买价</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">卖价</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">最新价</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Delta</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Gamma</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Theta</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Vega</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">隐含波动率</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">未平仓</th>
                            </tr>
                        </thead>
                        <tbody id="optionChainTableBody" class="bg-white divide-y divide-gray-200">
                            <!-- 数据将通过 JavaScript 动态填充 -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 功能说明 -->
        <div class="mt-6 bg-gray-50 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-3">期权 Greeks 说明</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-gray-600">
                <div>
                    <strong class="text-gray-900">Delta (Δ):</strong> 标的价格变动1美元时，期权价格的变化量
                </div>
                <div>
                    <strong class="text-gray-900">Gamma (Γ):</strong> 标的价格变动1美元时，Delta 的变化量
                </div>
                <div>
                    <strong class="text-gray-900">Theta (Θ):</strong> 时间流逝一天，期权价格的变化量（时间价值衰减）
                </div>
                <div>
                    <strong class="text-gray-900">Vega (ν):</strong> 隐含波动率变动1%时，期权价格的变化量
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function searchOptionChain() {
    const symbol = document.getElementById('optionSymbol').value.trim().toUpperCase();
    const contractType = document.getElementById('contractType').value;
    
    if (!symbol) {
        showOptionError('请输入股票代码');
        return;
    }

    // 显示加载状态
    document.getElementById('optionLoadingState').classList.remove('hidden');
    document.getElementById('optionErrorState').classList.add('hidden');
    document.getElementById('optionChainResult').classList.add('hidden');

    // TODO: 调用 API 获取期权链数据
    // 这里先显示模拟数据
    setTimeout(() => {
        document.getElementById('optionLoadingState').classList.add('hidden');
        showMockOptionChain(symbol, contractType);
    }, 1500);
}

function showMockOptionChain(symbol, contractType) {
    // 显示标的股票信息
    document.getElementById('underlyingSymbol').textContent = symbol;
    document.getElementById('underlyingPrice').textContent = '$150.25';
    document.getElementById('underlyingChange').innerHTML = '<span class="text-green-600">+2.50</span>';
    document.getElementById('underlyingChangePercent').innerHTML = '<span class="text-green-600">+1.69%</span>';
    document.getElementById('underlyingVolume').textContent = '45.2M';

    // 模拟期权链数据
    const mockOptions = [
        { expDate: '2026-05-15', strike: 145, type: 'CALL', bid: 8.50, ask: 8.70, last: 8.60, delta: 0.65, gamma: 0.02, theta: -0.15, vega: 0.25, iv: 28.5, oi: 1250 },
        { expDate: '2026-05-15', strike: 150, type: 'CALL', bid: 5.20, ask: 5.40, last: 5.30, delta: 0.50, gamma: 0.03, theta: -0.18, vega: 0.30, iv: 30.2, oi: 2100 },
        { expDate: '2026-05-15', strike: 155, type: 'CALL', bid: 2.80, ask: 3.00, last: 2.90, delta: 0.35, gamma: 0.02, theta: -0.12, vega: 0.22, iv: 32.1, oi: 980 },
        { expDate: '2026-05-15', strike: 145, type: 'PUT', bid: 3.20, ask: 3.40, last: 3.30, delta: -0.35, gamma: 0.02, theta: -0.12, vega: 0.22, iv: 29.8, oi: 850 },
        { expDate: '2026-05-15', strike: 150, type: 'PUT', bid: 5.50, ask: 5.70, last: 5.60, delta: -0.50, gamma: 0.03, theta: -0.18, vega: 0.30, iv: 31.5, oi: 1650 },
    ];

    // 根据合约类型筛选
    const filteredOptions = contractType === 'ALL' ? mockOptions : 
                           mockOptions.filter(opt => opt.type === contractType);

    // 填充表格
    const tbody = document.getElementById('optionChainTableBody');
    tbody.innerHTML = filteredOptions.map(opt => `
        <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">${opt.expDate}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900">$${opt.strike}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm">
                <span class="px-2 py-1 text-xs font-semibold rounded ${opt.type === 'CALL' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
                    ${opt.type}
                </span>
            </td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900">$${opt.bid.toFixed(2)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-900">$${opt.ask.toFixed(2)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right font-medium text-gray-900">$${opt.last.toFixed(2)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-700">${opt.delta.toFixed(3)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-700">${opt.gamma.toFixed(3)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-700">${opt.theta.toFixed(3)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-700">${opt.vega.toFixed(3)}</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-700">${opt.iv.toFixed(1)}%</td>
            <td class="px-4 py-3 whitespace-nowrap text-sm text-right text-gray-700">${opt.oi.toLocaleString()}</td>
        </tr>
    `).join('');

    document.getElementById('optionChainResult').classList.remove('hidden');
}

function showOptionError(message) {
    document.getElementById('optionErrorMessage').textContent = message;
    document.getElementById('optionErrorState').classList.remove('hidden');
    document.getElementById('optionLoadingState').classList.add('hidden');
    document.getElementById('optionChainResult').classList.add('hidden');
}
</script>

@{
    ViewData["Title"] = "股票行情查询";
}

<div class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
        <!-- 返回按钮 -->
        <div class="mb-4">
            <a href="@Url.Action("Index", "Schwab")" class="inline-flex items-center text-gray-600 hover:text-gray-900">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                返回嘉信理财主页
            </a>
        </div>

        <!-- 页面标题 -->
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">股票行情查询</h1>
            <p class="text-gray-600">查询美股实时报价和历史数据</p>
        </div>

        <!-- 搜索框 -->
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
            <div class="flex gap-4">
                <div class="flex-1">
                    <label for="symbolInput" class="block text-sm font-medium text-gray-700 mb-2">股票代码</label>
                    <input type="text" 
                           id="symbolInput" 
                           placeholder="输入股票代码，例如：AAPL, TSLA, MSFT" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent uppercase"
                           onkeypress="if(event.key === 'Enter') searchStock()">
                </div>
                <div class="flex items-end">
                    <button onclick="searchStock()" 
                            class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                        查询
                    </button>
                </div>
            </div>
        </div>

        <!-- 加载状态 -->
        <div id="loadingState" class="hidden bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
            <div class="flex items-center">
                <svg class="animate-spin h-5 w-5 text-blue-600 mr-3" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-blue-700">正在查询数据...</span>
            </div>
        </div>

        <!-- 错误提示 -->
        <div id="errorState" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex">
                <svg class="h-5 w-5 text-red-400 mr-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                </svg>
                <span id="errorMessage" class="text-red-700"></span>
            </div>
        </div>

        <!-- 报价结果 -->
        <div id="quoteResult" class="hidden">
            <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <h2 id="quoteSymbol" class="text-2xl font-bold text-gray-900"></h2>
                        <p id="quoteDescription" class="text-gray-600"></p>
                    </div>
                    <div class="text-right">
                        <div id="quotePrice" class="text-3xl font-bold text-gray-900"></div>
                        <div id="quoteChange" class="text-lg font-semibold"></div>
                    </div>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pt-4 border-t border-gray-200">
                    <div>
                        <div class="text-sm text-gray-600">开盘价</div>
                        <div id="quoteOpen" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">最高价</div>
                        <div id="quoteHigh" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">最低价</div>
                        <div id="quoteLow" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                    <div>
                        <div class="text-sm text-gray-600">成交量</div>
                        <div id="quoteVolume" class="text-lg font-semibold text-gray-900"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 功能提示 -->
        <div class="bg-gray-50 rounded-lg p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-3">使用说明</h3>
            <ul class="space-y-2 text-gray-600">
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span>输入美股代码（如 AAPL, TSLA, MSFT）进行查询</span>
                </li>
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span>数据来源于嘉信理财 API，延迟约15分钟</span>
                </li>
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                    </svg>
                    <span>支持查询所有在美国交易所上市的股票</span>
                </li>
            </ul>
        </div>
    </div>
</div>

<script>
function searchStock() {
    const symbol = document.getElementById('symbolInput').value.trim().toUpperCase();
    
    if (!symbol) {
        showError('请输入股票代码');
        return;
    }

    // 显示加载状态
    document.getElementById('loadingState').classList.remove('hidden');
    document.getElementById('errorState').classList.add('hidden');
    document.getElementById('quoteResult').classList.add('hidden');

    // TODO: 调用 API 获取数据
    // 这里先显示模拟数据
    setTimeout(() => {
        document.getElementById('loadingState').classList.add('hidden');
        showMockData(symbol);
    }, 1000);
}

function showMockData(symbol) {
    // 模拟数据（实际应该调用 API）
    document.getElementById('quoteSymbol').textContent = symbol;
    document.getElementById('quoteDescription').textContent = '示例公司 - 需要实现 API 调用';
    document.getElementById('quotePrice').textContent = '$150.25';
    document.getElementById('quoteChange').innerHTML = '<span class="text-green-600">+2.50 (+1.69%)</span>';
    document.getElementById('quoteOpen').textContent = '$148.50';
    document.getElementById('quoteHigh').textContent = '$151.00';
    document.getElementById('quoteLow').textContent = '$147.80';
    document.getElementById('quoteVolume').textContent = '45.2M';
    
    document.getElementById('quoteResult').classList.remove('hidden');
}

function showError(message) {
    document.getElementById('errorMessage').textContent = message;
    document.getElementById('errorState').classList.remove('hidden');
    document.getElementById('loadingState').classList.add('hidden');
    document.getElementById('quoteResult').classList.add('hidden');
}
</script>

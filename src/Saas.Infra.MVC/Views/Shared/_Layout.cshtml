<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Saas.Infra</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/app.css" />
</head>
<body class="bg-gray-50">
    <!-- 导航栏 -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="text-xl font-bold text-blue-600">Saas.Infra</a>
                    <div class="ml-10 flex items-baseline space-x-4">
                        <a href="/dashboard" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">Dashboard</a>
                        <a href="/Schwab/Index" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">嘉信理财</a>
                        <a href="/products" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">Products</a>
                    </div>
                </div>
                <div class="flex items-center">
                    <span class="text-gray-700 text-sm mr-4">@User.Identity?.Name</span>
                    <a href="/Account/Logout" class="text-gray-700 hover:text-blue-600 px-3 py-2 rounded-md text-sm font-medium">退出</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- 主内容 -->
    <main>
        @RenderBody()
    </main>

    <!-- 页脚 -->
    <footer class="bg-white border-t border-gray-200 mt-12">
        <div class="container mx-auto px-4 py-6">
            <p class="text-center text-gray-600 text-sm">
                &copy; 2026 Saas.Infra - Powered by .NET 8
            </p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

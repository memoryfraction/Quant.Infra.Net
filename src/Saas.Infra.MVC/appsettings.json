{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "Saas.Infra.SSO",
    "Audience": "Saas.Infra.Clients",
    "AccessTokenExpirationMinutes": 60,
    "PrivateKeyPath": "Secrets/sso_rsa_private.pem",
    "PublicKeyPath": "PublicKeys/sso_rsa_public.pem"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Stripe": {
    "PublishableKey": "",
    "SecretKey": "",
    "WebhookSecret": ""
  },
  "Schwab": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "https://127.0.0.1:5179/schwab/callback",
    "BaseUrl": "https://api.schwabapi.com",
    "AuthorizationEndpoint": "https://api.schwabapi.com/v1/oauth/authorize",
    "TokenEndpoint": "https://api.schwabapi.com/v1/oauth/token",
    "TraderApiPath": "/trader/v1",
    "MarketDataApiPath": "/marketdata/v1",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7,
    "TokenRefreshAdvanceMinutes": 1,
    "RequestTimeoutSeconds": 30,
    "MaxRetryCount": 3,
    "EnableAutoTokenRefresh": true
  }
}
